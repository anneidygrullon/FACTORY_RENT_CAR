<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.factory_rent_car.Controlador.ClienteController"
            style="-fx-background-color: #F8FAFC; -fx-background: #F8FAFC; -fx-border-color: transparent;">

    <VBox spacing="16" style="-fx-background-color: #F8FAFC; -fx-padding: 20;">

        <!-- Barra de búsqueda y filtros -->
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label text="Buscar:" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
            <TextField fx:id="txtBuscar" promptText="Nombre, identificación, licencia..." HBox.hgrow="ALWAYS"
                       style="-fx-background-radius: 6; -fx-border-color: #E2E8F0; -fx-border-radius: 6; -fx-padding: 6 10;"/>
            <Button text="Buscar" onAction="#buscar"
                    style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 6 16;"/>
            <Button text="Limpiar filtro" onAction="#limpiarFiltro"
                    style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-background-radius: 6; -fx-padding: 6 16;"/>
        </HBox>

        <!-- Sección Tabla de Clientes (con botón ocultar/mostrar) -->
        <VBox fx:id="tableContainer" spacing="8" style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12;">
            <HBox alignment="CENTER_LEFT">
                <Label text="Lista de Clientes" style="-fx-text-fill: #0F172A; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnToggleTable" text="📋 Ocultar Tabla" onAction="#toggleTableVisibility"
                        style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-font-size: 11px; -fx-background-radius: 6; -fx-padding: 4 12; -fx-cursor: hand;"/>
            </HBox>
            <TableView fx:id="tablaClientes" prefHeight="350">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colNombre" text="Nombre" prefWidth="180"/>
                    <TableColumn fx:id="colEdad" text="Edad" prefWidth="60"/>
                    <TableColumn fx:id="colFechaNac" text="Fec. Nacimiento" prefWidth="110"/>
                    <TableColumn fx:id="colCorreo" text="Correo" prefWidth="200"/>
                    <TableColumn fx:id="colTelefono" text="Teléfono" prefWidth="120"/>
                    <TableColumn fx:id="colIdentificacion" text="Identificación" prefWidth="130"/>
                    <TableColumn fx:id="colLicencia" text="Licencia" prefWidth="100"/>
                    <TableColumn fx:id="colNacionalidad" text="Nacionalidad" prefWidth="100"/>
                    <TableColumn fx:id="colPasaporte" text="Pasaporte" prefWidth="100"/>
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                <placeholder><Label text="No hay clientes registrados"/></placeholder>
            </TableView>
        </VBox>

        <!-- Formulario de edición / alta -->
        <VBox spacing="12" style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 16;">
            <Label fx:id="lblTituloFormulario" text="Nuevo Cliente" style="-fx-text-fill: #0F172A; -fx-font-size: 14px; -fx-font-weight: bold;"/>

            <GridPane hgap="12" vgap="10">
                <columnConstraints>
                    <ColumnConstraints percentWidth="15"/>
                    <ColumnConstraints percentWidth="35"/>
                    <ColumnConstraints percentWidth="15"/>
                    <ColumnConstraints percentWidth="35"/>
                </columnConstraints>

                <Label text="Nombre *" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextField fx:id="txtNombre" GridPane.columnIndex="1" GridPane.rowIndex="0" promptText="Nombre completo"/>

                <Label text="Edad" GridPane.columnIndex="2" GridPane.rowIndex="0" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextField fx:id="txtEdad" GridPane.columnIndex="3" GridPane.rowIndex="0" promptText="(se calcula automáticamente)"/>

                <Label text="Fecha Nacimiento *" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <DatePicker fx:id="dpFechaNacimiento" GridPane.columnIndex="1" GridPane.rowIndex="1" promptText="dd/mm/yyyy"/>

                <Label text="Correo *" GridPane.columnIndex="2" GridPane.rowIndex="1" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextField fx:id="txtCorreo" GridPane.columnIndex="3" GridPane.rowIndex="1" promptText="cliente@email.com"/>

                <Label text="Teléfono *" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextField fx:id="txtTelefono" GridPane.columnIndex="1" GridPane.rowIndex="2" promptText="809-555-1234"/>

                <Label text="Identificación" GridPane.columnIndex="2" GridPane.rowIndex="2" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextField fx:id="txtIdentificacion" GridPane.columnIndex="3" GridPane.rowIndex="2" promptText="Cédula / RNC (opcional)"/>

                <Label text="Licencia *" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextField fx:id="txtLicencia" GridPane.columnIndex="1" GridPane.rowIndex="3" promptText="Número de licencia"/>

                <Label text="Nacionalidad *" GridPane.columnIndex="2" GridPane.rowIndex="3" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextField fx:id="txtNacionalidad" GridPane.columnIndex="3" GridPane.rowIndex="3" promptText="País de origen"/>

                <Label text="Nº Pasaporte" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextField fx:id="txtPasaporte" GridPane.columnIndex="1" GridPane.rowIndex="4" promptText="Opcional"/>
            </GridPane>

            <HBox alignment="CENTER_RIGHT" spacing="12">
                <Button text="Limpiar" onAction="#limpiarFormulario"
                        style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-background-radius: 6; -fx-padding: 8 20;"/>
                <Button fx:id="btnGuardar" text="Guardar" onAction="#guardarCliente"
                        style="-fx-background-color: #1565C0; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 8 28;"/>
                <Button fx:id="btnEliminar" text="Eliminar" onAction="#eliminarCliente"
                        style="-fx-background-color: #FEF2F2; -fx-text-fill: #DC2626; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 8 20;"/>
            </HBox>
        </VBox>
    </VBox>
</ScrollPane>