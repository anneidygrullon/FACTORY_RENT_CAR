<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.factory_rent_car.Controlador.ConsultaDepartamentoController"
            style="-fx-background-color: #eef2f8; -fx-background: #eef2f8; -fx-border-color: transparent;">

    <VBox spacing="24" style="-fx-background-color: #eef2f8; -fx-padding: 30 35 35 35;">

        <HBox alignment="CENTER_LEFT" spacing="12">
            <StackPane minWidth="32" maxWidth="32" minHeight="32" maxHeight="32"
                       style="-fx-background-color: #1565C0; -fx-background-radius: 8;">
                <Label text="🏢" style="-fx-font-size: 16px;"/>
            </StackPane>
            <VBox spacing="2">
                <Label text="Departamentos" style="-fx-text-fill: #0F172A; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Label text="Consulta y administración de departamentos" style="-fx-text-fill: #94A3B8; -fx-font-size: 11px;"/>
            </VBox>
        </HBox>

        <HBox spacing="12" alignment="CENTER_LEFT"
              style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2); -fx-padding: 14 18;">
            <Label text="🔍" style="-fx-font-size: 16px;"/>
            <TextField fx:id="txtBuscar" promptText="Buscar por nombre o teléfono..." HBox.hgrow="ALWAYS"
                       style="-fx-background-radius: 8; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-padding: 8 14; -fx-font-size: 13px;"/>
            <Button text="Buscar" onAction="#buscar"
                    style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 20; -fx-cursor: hand;"/>
            <Button text="Limpiar" onAction="#limpiarFiltro"
                    style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-background-radius: 8; -fx-padding: 8 20; -fx-cursor: hand; -fx-border-color: #E2E8F0; -fx-border-radius: 8;"/>
        </HBox>

        <VBox fx:id="tableContainer" spacing="0"
              style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3); -fx-padding: 0;">
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-padding: 16 20; -fx-border-color: transparent transparent #F1F5F9 transparent; -fx-border-width: 0 0 1 0;">
                <Label text="📋" style="-fx-font-size: 16px;"/>
                <Label text="Lista de Departamentos" style="-fx-text-fill: #0F172A; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnToggleTable" text="Ocultar Tabla" onAction="#toggleTableVisibility"
                        style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 6 14; -fx-cursor: hand; -fx-border-color: #E2E8F0; -fx-border-radius: 8;"/>
            </HBox>
            <TableView fx:id="tablaDepartamentos" prefHeight="350"
                       style="-fx-background-color: transparent; -fx-border-color: transparent;">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colNombre" text="Nombre" prefWidth="250"/>
                    <TableColumn fx:id="colTelefono" text="Teléfono" prefWidth="150"/>
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                <placeholder>
                    <VBox alignment="CENTER" spacing="8">
                        <Label text="📋" style="-fx-font-size: 32px;"/>
                        <Label text="No hay departamentos registrados" style="-fx-text-fill: #94A3B8; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                    </VBox>
                </placeholder>
            </TableView>
        </VBox>

        <VBox spacing="0"
              style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3);">
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color: #F8FAFC; -fx-background-radius: 14 14 0 0; -fx-padding: 16 20; -fx-border-color: transparent transparent #E2E8F0 transparent; -fx-border-width: 0 0 1 0;">
                <StackPane minWidth="28" maxWidth="28" minHeight="28" maxHeight="28"
                           style="-fx-background-color: #1565C0; -fx-background-radius: 7;">
                    <Label text="+" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                </StackPane>
                <Label fx:id="lblTitulo" text="Registro de Departamento" style="-fx-text-fill: #0F172A; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="* Campos obligatorios" style="-fx-text-fill: #94A3B8; -fx-font-size: 10px;"/>
            </HBox>

            <VBox spacing="16" style="-fx-padding: 20 24 20 24;">
                <GridPane hgap="16" vgap="12">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="20"/>
                        <ColumnConstraints percentWidth="30"/>
                        <ColumnConstraints percentWidth="20"/>
                        <ColumnConstraints percentWidth="30"/>
                    </columnConstraints>

                    <Label text="ID Departamento:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtIdDepartamento" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="0"
                               style="-fx-background-color: #F8FAFC; -fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;"/>

                    <Label text="Nombre *" GridPane.columnIndex="2" GridPane.rowIndex="0" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtNombre" GridPane.columnIndex="3" GridPane.rowIndex="0" promptText="Ej: Recursos Humanos"
                               style="-fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;"/>

                    <Label text="Teléfono *" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtTelefono" GridPane.columnIndex="1" GridPane.rowIndex="1" promptText="809-555-1234"
                               style="-fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;"/>
                </GridPane>

                <HBox alignment="CENTER_RIGHT" spacing="12" style="-fx-padding: 4 0 0 0;">
                    <Button text="Limpiar" onAction="#limpiar"
                            style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 24; -fx-cursor: hand; -fx-border-color: #E2E8F0; -fx-border-radius: 8;"/>
                    <Button text="Guardar" onAction="#guardarDepartamento"
                            style="-fx-background-color: #1565C0; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 28; -fx-cursor: hand;"/>
                    <Button text="Eliminar" onAction="#eliminarDepartamento"
                            style="-fx-background-color: #FEF2F2; -fx-text-fill: #DC2626; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 24; -fx-cursor: hand; -fx-border-color: #FECACA; -fx-border-radius: 8;"/>
                </HBox>
            </VBox>
        </VBox>
    </VBox>
</ScrollPane>
