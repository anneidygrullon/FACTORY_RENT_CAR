<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.factory_rent_car.Controlador.EntregaVehiculoController"
            style="-fx-background-color: #F8FAFC; -fx-background: #F8FAFC; -fx-border-color: transparent;">

    <VBox spacing="16" style="-fx-background-color: #F8FAFC; -fx-padding: 20;">

        <!-- Barra de búsqueda -->
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label text="Buscar:" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
            <TextField fx:id="txtBuscar" promptText="Cliente, vehículo, empleado..." HBox.hgrow="ALWAYS"
                       style="-fx-background-radius: 6; -fx-border-color: #E2E8F0; -fx-border-radius: 6; -fx-padding: 6 10;"/>
            <Button text="Buscar" onAction="#buscar"
                    style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 6 16;"/>
            <Button text="Limpiar filtro" onAction="#limpiarFiltro"
                    style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-background-radius: 6; -fx-padding: 6 16;"/>
        </HBox>

        <!-- Tabla de entregas (ocultable) -->
        <VBox fx:id="tableContainer" spacing="8" style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12;">
            <HBox alignment="CENTER_LEFT">
                <Label text="Lista de Entregas" style="-fx-text-fill: #0F172A; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnToggleTable" text="📋 Ocultar Tabla" onAction="#toggleTableVisibility"
                        style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-font-size: 11px; -fx-background-radius: 6; -fx-padding: 4 12; -fx-cursor: hand;"/>
            </HBox>
            <TableView fx:id="tablaEntregas" prefHeight="350">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colFecha" text="Fecha" prefWidth="100"/>
                    <TableColumn fx:id="colCliente" text="Cliente" prefWidth="180"/>
                    <TableColumn fx:id="colVehiculo" text="Vehículo" prefWidth="180"/>
                    <TableColumn fx:id="colCombustible" text="Nivel Combustible" prefWidth="120"/>
                    <TableColumn fx:id="colTipo" text="Tipo" prefWidth="80"/>
                    <TableColumn fx:id="colEmpleado" text="Empleado" prefWidth="150"/>
                    <TableColumn fx:id="colDireccion" text="Dirección" prefWidth="200"/>
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                <placeholder><Label text="No hay registros de entregas"/></placeholder>
            </TableView>
        </VBox>

        <!-- Formulario de detalle / edición -->
        <VBox spacing="12" style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 16;">
            <Label fx:id="lblTitulo" text="Detalle de Entrega" style="-fx-text-fill: #0F172A; -fx-font-size: 14px; -fx-font-weight: bold;"/>

            <GridPane hgap="12" vgap="10">
                <columnConstraints>
                    <ColumnConstraints percentWidth="20"/>
                    <ColumnConstraints percentWidth="30"/>
                    <ColumnConstraints percentWidth="20"/>
                    <ColumnConstraints percentWidth="30"/>
                </columnConstraints>

                <Label text="Reserva ID:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextField fx:id="txtIdReserva" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="Cliente:" GridPane.columnIndex="2" GridPane.rowIndex="0" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextField fx:id="txtCliente" editable="false" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

                <Label text="Vehículo:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextField fx:id="txtVehiculo" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Empleado:" GridPane.columnIndex="2" GridPane.rowIndex="1" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextField fx:id="txtEmpleado" editable="false" GridPane.columnIndex="3" GridPane.rowIndex="1"/>

                <Label text="Dirección:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <ComboBox fx:id="cmbDireccion" GridPane.columnIndex="1" GridPane.rowIndex="2" GridPane.columnSpan="3" promptText="Seleccione una dirección"/>

                <Label text="Fecha:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <DatePicker fx:id="dpFecha" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                <Label text="Nivel Combustible:" GridPane.columnIndex="2" GridPane.rowIndex="3" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextField fx:id="txtNivelCombustible" GridPane.columnIndex="3" GridPane.rowIndex="3"/>

                <Label text="Tipo:" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <ComboBox fx:id="cmbTipo" GridPane.columnIndex="1" GridPane.rowIndex="4" promptText="Seleccione"/>
            </GridPane>

            <HBox alignment="CENTER_RIGHT" spacing="12">
                <Button text="Actualizar" onAction="#actualizarEntrega"
                        style="-fx-background-color: #1565C0; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 8 20;"/>
                <Button text="Marcar como Entregado (Reservar)" onAction="#marcarEntregado"
                        style="-fx-background-color: #2E7D32; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 8 20;"/>
                <Button text="Limpiar" onAction="#limpiar"
                        style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-background-radius: 6; -fx-padding: 8 20;"/>
            </HBox>
        </VBox>
    </VBox>
</ScrollPane>