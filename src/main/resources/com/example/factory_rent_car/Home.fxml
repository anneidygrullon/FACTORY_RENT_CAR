<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            style="-fx-background-color: #eef2f8; -fx-background: #eef2f8; -fx-border-color: transparent;"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.factory_rent_car.Controlador.HomeController">

    <VBox spacing="30" alignment="TOP_CENTER" style="-fx-background-color: #eef2f8; -fx-padding: 30 40 40 40;">

        <!-- Encabezado de bienvenida -->
        <VBox alignment="CENTER" spacing="10">
            <Label text="🏭 FACTORY RENT CAR" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #0d0d1a;"/>
            <Label text="Sistema de Gestión de Reservas" style="-fx-font-size: 14px; -fx-text-fill: #5a6e8a;"/>
            <Label text="Bienvenido, Administrador" style="-fx-font-size: 16px; -fx-text-fill: #1565C0; -fx-font-weight: bold; -fx-padding: 0 0 10 0;"/>
            <Region prefHeight="2" prefWidth="100" style="-fx-background-color: #1565C0; -fx-background-radius: 2;"/>
        </VBox>

        <!-- Grid de accesos rápidos (2 columnas) -->
        <GridPane hgap="25" vgap="25" alignment="CENTER">
            <columnConstraints>
                <ColumnConstraints percentWidth="50"/>
                <ColumnConstraints percentWidth="50"/>
            </columnConstraints>

            <!-- Tarjeta 1: Registrar Cliente -->
            <VBox fx:id="cardCliente" spacing="15" alignment="CENTER"
                  style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 5); -fx-padding: 25; -fx-cursor: hand;"
                  onMouseClicked="#irARegistrarCliente" onMouseEntered="#onCardEnter" onMouseExited="#onCardExit">
                <Label text="👥" style="-fx-font-size: 48px;"/>
                <Label text="Registrar Cliente" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Label text="Añade un nuevo cliente al sistema" style="-fx-font-size: 12px; -fx-text-fill: #64748b; -fx-text-alignment: center;" wrapText="true"/>
            </VBox>

            <!-- Tarjeta 2: Registrar Reserva -->
            <VBox fx:id="cardReserva" spacing="15" alignment="CENTER"
                  style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 5); -fx-padding: 25; -fx-cursor: hand;"
                  onMouseClicked="#irARegistrarReserva" onMouseEntered="#onCardEnter" onMouseExited="#onCardExit">
                <Label text="📅" style="-fx-font-size: 48px;"/>
                <Label text="Registrar Reserva" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Label text="Crea una nueva reserva de vehículo" style="-fx-font-size: 12px; -fx-text-fill: #64748b; -fx-text-alignment: center;" wrapText="true"/>
            </VBox>

            <!-- Tarjeta 3: Registrar Incidencia -->
            <VBox fx:id="cardIncidencia" spacing="15" alignment="CENTER"
                  style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 5); -fx-padding: 25; -fx-cursor: hand;"
                  onMouseClicked="#irARegistrarIncidencia" onMouseEntered="#onCardEnter" onMouseExited="#onCardExit">
                <Label text="⚠️" style="-fx-font-size: 48px;"/>
                <Label text="Registrar Incidencia" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Label text="Reporta una incidencia o daño" style="-fx-font-size: 12px; -fx-text-fill: #64748b; -fx-text-alignment: center;" wrapText="true"/>
            </VBox>

            <!-- Tarjeta 4: Registrar Entrega -->
            <VBox fx:id="cardEntrega" spacing="15" alignment="CENTER"
                  style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 5); -fx-padding: 25; -fx-cursor: hand;"
                  onMouseClicked="#irARegistrarEntrega" onMouseEntered="#onCardEnter" onMouseExited="#onCardExit">
                <Label text="🚚" style="-fx-font-size: 48px;"/>
                <Label text="Registrar Entrega" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Label text="Registra la entrega de un vehículo" style="-fx-font-size: 12px; -fx-text-fill: #64748b; -fx-text-alignment: center;" wrapText="true"/>
            </VBox>
        </GridPane>

        <!-- Pie de página -->
        <HBox alignment="CENTER" spacing="20">
            <Label text="© 2025 Factory Rent Car - Tu camino, nuestra prioridad." style="-fx-font-size: 11px; -fx-text-fill: #94a3b8;"/>
        </HBox>
    </VBox>
</ScrollPane>