<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: #eef2f8; -fx-background: #eef2f8; -fx-border-color: transparent;" vbarPolicy="AS_NEEDED" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.factory_rent_car.Controlador.HomeController">

    <VBox alignment="TOP_CENTER" spacing="28" style="-fx-background-color: #eef2f8; -fx-padding: 35 40 40 40;">

        <HBox alignment="CENTER_LEFT" maxWidth="1100" spacing="16" HBox.hgrow="ALWAYS">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #0F172A;" text="🏭 Factory Rent Car" />
                <Label style="-fx-font-size: 13px; -fx-text-fill: #64748B;" text="Panel de control — gestiona tu flota de vehículos" />
            </VBox>
            <VBox alignment="CENTER_RIGHT" spacing="2">
                <Label style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;" text="Bienvenido," />
                <Label fx:id="lblUsuario" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1565C0;" text="Administrador" />
            </VBox>
        </HBox>

        <Region maxWidth="1100" prefHeight="1" style="-fx-background-color: #E2E8F0;" />

        <HBox alignment="CENTER" maxWidth="1100" spacing="20" HBox.hgrow="ALWAYS">
            <VBox alignment="CENTER" spacing="6" style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 3); -fx-padding: 20 10;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 28px;" text="🚗" />
                <Label style="-fx-font-size: 11px; -fx-text-fill: #94A3B8; -fx-font-weight: bold;" text="Vehículos" />
                <Label style="-fx-font-size: 11px; -fx-text-fill: #64748B;" text="Gestión completa" />
            </VBox>
            <VBox alignment="CENTER" spacing="6" style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 3); -fx-padding: 20 10;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 28px;" text="👥" />
                <Label style="-fx-font-size: 11px; -fx-text-fill: #94A3B8; -fx-font-weight: bold;" text="Clientes" />
                <Label style="-fx-font-size: 11px; -fx-text-fill: #64748B;" text="Registro y consulta" />
            </VBox>
            <VBox alignment="CENTER" spacing="6" style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 3); -fx-padding: 20 10;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 28px;" text="📅" />
                <Label style="-fx-font-size: 11px; -fx-text-fill: #94A3B8; -fx-font-weight: bold;" text="Reservas" />
                <Label style="-fx-font-size: 11px; -fx-text-fill: #64748B;" text="Activas y programadas" />
            </VBox>
            <VBox alignment="CENTER" spacing="6" style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 3); -fx-padding: 20 10;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 28px;" text="⚠" />
                <Label style="-fx-font-size: 11px; -fx-text-fill: #94A3B8; -fx-font-weight: bold;" text="Incidencias" />
                <Label style="-fx-font-size: 11px; -fx-text-fill: #64748B;" text="Reportes activos" />
            </VBox>
        </HBox>

        <VBox maxWidth="1100" spacing="16" VBox.vgrow="ALWAYS">
            <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #0F172A;" text="Acceso Rápido" />

            <GridPane alignment="CENTER" hgap="20" vgap="20">
                <columnConstraints>
                    <ColumnConstraints percentWidth="25" />
                    <ColumnConstraints percentWidth="25" />
                    <ColumnConstraints percentWidth="25" />
                    <ColumnConstraints percentWidth="25" />
                </columnConstraints>

                <VBox fx:id="cardClientes" alignment="CENTER" onMouseClicked="#irAClientes" onMouseEntered="#onCardEnter" onMouseExited="#onCardExit" spacing="12" style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 4); -fx-padding: 24 14; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 42px;" text="👥" />
                    <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Clientes" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #64748b; -fx-text-alignment: center;" text="Registrar y consultar clientes" wrapText="true" />
                </VBox>

                <VBox fx:id="cardReservaVehiculo" alignment="CENTER" onMouseClicked="#irAReservaVehiculo" onMouseEntered="#onCardEnter" onMouseExited="#onCardExit" spacing="12" style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 4); -fx-padding: 24 14; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 42px;" text="🚗" />
                    <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Reserva Vehículos" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #64748b; -fx-text-alignment: center;" text="Crear reserva de vehículos" wrapText="true" />
                </VBox>

                <VBox fx:id="cardReservaObjeto" alignment="CENTER" onMouseClicked="#irAReservaObjeto" onMouseEntered="#onCardEnter" onMouseExited="#onCardExit" spacing="12" style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 4); -fx-padding: 24 14; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 42px;" text="📦" />
                    <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Reserva Objetos" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #64748b; -fx-text-alignment: center;" text="Reservar objetos y accesorios" wrapText="true" />
                </VBox>

                <VBox fx:id="cardIncidencia" alignment="CENTER" onMouseClicked="#irAIncidencia" onMouseEntered="#onCardEnter" onMouseExited="#onCardExit" spacing="12" style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 4); -fx-padding: 24 14; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 42px;" text="⚠️" />
                    <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Incidencias" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #64748b; -fx-text-alignment: center;" text="Reportar y consultar incidencias" wrapText="true" />
                </VBox>

                <VBox fx:id="cardGestionVehiculo" alignment="CENTER" onMouseClicked="#irAGestionVehiculo" onMouseEntered="#onCardEnter" onMouseExited="#onCardExit" spacing="12" style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 4); -fx-padding: 24 14; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 42px;" text="🚚" />
                    <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Gestión de Vehículo" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #64748b; -fx-text-alignment: center;" text="Gestionar entregas y devoluciones" wrapText="true" />
                </VBox>

                <VBox fx:id="cardVehiculos" alignment="CENTER" onMouseClicked="#irAVehiculos" onMouseEntered="#onCardEnter" onMouseExited="#onCardExit" spacing="12" style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 4); -fx-padding: 24 14; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 42px;" text="🔧" />
                    <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Vehículos" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #64748b; -fx-text-alignment: center;" text="Consultar y gestionar flota" wrapText="true" />
                </VBox>

                <VBox fx:id="cardReclamos" alignment="CENTER" onMouseClicked="#irAReclamos" onMouseEntered="#onCardEnter" onMouseExited="#onCardExit" spacing="12" style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 4); -fx-padding: 24 14; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 42px;" text="📢" />
                    <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Reclamos" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #64748b; -fx-text-alignment: center;" text="Gestionar reclamos de clientes" wrapText="true" />
                </VBox>
            <rowConstraints>
               <RowConstraints />
            </rowConstraints>
            </GridPane>
        </VBox>

        <HBox alignment="CENTER" spacing="20" style="-fx-padding: 10 0 0 0;">
            <Label style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;" text="© 2025 Factory Rent Car — Sistema de Gestión de Flota" />
        </HBox>
    </VBox>
</ScrollPane>
