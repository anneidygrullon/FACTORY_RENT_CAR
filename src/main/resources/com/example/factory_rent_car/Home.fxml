<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            style="-fx-background-color: #eef2f8; -fx-background: #eef2f8; -fx-border-color: transparent;"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.factory_rent_car.Controlador.HomeController">

    <VBox spacing="28" alignment="TOP_CENTER" style="-fx-background-color: #eef2f8; -fx-padding: 35 40 40 40;">

        <HBox alignment="CENTER_LEFT" spacing="16" maxWidth="1100" HBox.hgrow="ALWAYS">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="🏭 Factory Rent Car" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
                <Label text="Panel de control — gestiona tu flota de vehículos" style="-fx-font-size: 13px; -fx-text-fill: #64748B;"/>
            </VBox>
            <VBox alignment="CENTER_RIGHT" spacing="2">
                <Label text="Bienvenido," style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;"/>
                <Label fx:id="lblUsuario" text="Administrador" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1565C0;"/>
            </VBox>
        </HBox>

        <Region maxWidth="1100" prefHeight="1" style="-fx-background-color: #E2E8F0;"/>

        <HBox spacing="20" alignment="CENTER" maxWidth="1100" HBox.hgrow="ALWAYS">
            <VBox spacing="6" alignment="CENTER" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 3); -fx-padding: 20 10;">
                <Label text="🚗" style="-fx-font-size: 28px;"/>
                <Label text="Vehículos" style="-fx-font-size: 11px; -fx-text-fill: #94A3B8; -fx-font-weight: bold;"/>
                <Label text="Gestión completa" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
            </VBox>
            <VBox spacing="6" alignment="CENTER" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 3); -fx-padding: 20 10;">
                <Label text="👥" style="-fx-font-size: 28px;"/>
                <Label text="Clientes" style="-fx-font-size: 11px; -fx-text-fill: #94A3B8; -fx-font-weight: bold;"/>
                <Label text="Registro y consulta" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
            </VBox>
            <VBox spacing="6" alignment="CENTER" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 3); -fx-padding: 20 10;">
                <Label text="📅" style="-fx-font-size: 28px;"/>
                <Label text="Reservas" style="-fx-font-size: 11px; -fx-text-fill: #94A3B8; -fx-font-weight: bold;"/>
                <Label text="Activas y programadas" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
            </VBox>
            <VBox spacing="6" alignment="CENTER" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 3); -fx-padding: 20 10;">
                <Label text="⚠️" style="-fx-font-size: 28px;"/>
                <Label text="Incidencias" style="-fx-font-size: 11px; -fx-text-fill: #94A3B8; -fx-font-weight: bold;"/>
                <Label text="Reportes activos" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
            </VBox>
        </HBox>

        <VBox spacing="16" maxWidth="1100" VBox.vgrow="ALWAYS">
            <Label text="Acceso Rápido" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>

            <GridPane hgap="20" vgap="20" alignment="CENTER">
                <columnConstraints>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                </columnConstraints>

                <VBox fx:id="cardClientes" spacing="12" alignment="CENTER"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 4); -fx-padding: 24 14; -fx-cursor: hand;"
                      onMouseClicked="#irAClientes" onMouseEntered="#onCardEnter" onMouseExited="#onCardExit">
                    <Label text="👥" style="-fx-font-size: 42px;"/>
                    <Label text="Clientes" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Label text="Registrar y consultar clientes" style="-fx-font-size: 11px; -fx-text-fill: #64748b; -fx-text-alignment: center;" wrapText="true"/>
                </VBox>

                <VBox fx:id="cardReservaVehiculo" spacing="12" alignment="CENTER"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 4); -fx-padding: 24 14; -fx-cursor: hand;"
                      onMouseClicked="#irAReservaVehiculo" onMouseEntered="#onCardEnter" onMouseExited="#onCardExit">
                    <Label text="🚗" style="-fx-font-size: 42px;"/>
                    <Label text="Reserva Vehículos" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Label text="Crear reserva de vehículos" style="-fx-font-size: 11px; -fx-text-fill: #64748b; -fx-text-alignment: center;" wrapText="true"/>
                </VBox>

                <VBox fx:id="cardReservaObjeto" spacing="12" alignment="CENTER"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 4); -fx-padding: 24 14; -fx-cursor: hand;"
                      onMouseClicked="#irAReservaObjeto" onMouseEntered="#onCardEnter" onMouseExited="#onCardExit">
                    <Label text="📦" style="-fx-font-size: 42px;"/>
                    <Label text="Reserva Objetos" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Label text="Reservar objetos y accesorios" style="-fx-font-size: 11px; -fx-text-fill: #64748b; -fx-text-alignment: center;" wrapText="true"/>
                </VBox>

                <VBox fx:id="cardIncidencia" spacing="12" alignment="CENTER"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 4); -fx-padding: 24 14; -fx-cursor: hand;"
                      onMouseClicked="#irAIncidencia" onMouseEntered="#onCardEnter" onMouseExited="#onCardExit">
                    <Label text="⚠️" style="-fx-font-size: 42px;"/>
                    <Label text="Incidencias" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Label text="Reportar y consultar incidencias" style="-fx-font-size: 11px; -fx-text-fill: #64748b; -fx-text-alignment: center;" wrapText="true"/>
                </VBox>

                <VBox fx:id="cardEntrega" spacing="12" alignment="CENTER"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 4); -fx-padding: 24 14; -fx-cursor: hand;"
                      onMouseClicked="#irAEntrega" onMouseEntered="#onCardEnter" onMouseExited="#onCardExit">
                    <Label text="🚚" style="-fx-font-size: 42px;"/>
                    <Label text="Registro de Entrega" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Label text="Entregar vehículo al cliente" style="-fx-font-size: 11px; -fx-text-fill: #64748b; -fx-text-alignment: center;" wrapText="true"/>
                </VBox>

                <VBox fx:id="cardDevolucion" spacing="12" alignment="CENTER"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 4); -fx-padding: 24 14; -fx-cursor: hand;"
                      onMouseClicked="#irADevolucion" onMouseEntered="#onCardEnter" onMouseExited="#onCardExit">
                    <Label text="🔙" style="-fx-font-size: 42px;"/>
                    <Label text="Devolución" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Label text="Registrar devolución de vehículo" style="-fx-font-size: 11px; -fx-text-fill: #64748b; -fx-text-alignment: center;" wrapText="true"/>
                </VBox>

                <VBox fx:id="cardVehiculos" spacing="12" alignment="CENTER"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 4); -fx-padding: 24 14; -fx-cursor: hand;"
                      onMouseClicked="#irAVehiculos" onMouseEntered="#onCardEnter" onMouseExited="#onCardExit">
                    <Label text="🔧" style="-fx-font-size: 42px;"/>
                    <Label text="Vehículos" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Label text="Consultar y gestionar flota" style="-fx-font-size: 11px; -fx-text-fill: #64748b; -fx-text-alignment: center;" wrapText="true"/>
                </VBox>

                <VBox fx:id="cardReclamos" spacing="12" alignment="CENTER"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 4); -fx-padding: 24 14; -fx-cursor: hand;"
                      onMouseClicked="#irAReclamos" onMouseEntered="#onCardEnter" onMouseExited="#onCardExit">
                    <Label text="📢" style="-fx-font-size: 42px;"/>
                    <Label text="Reclamos" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Label text="Gestionar reclamos de clientes" style="-fx-font-size: 11px; -fx-text-fill: #64748b; -fx-text-alignment: center;" wrapText="true"/>
                </VBox>
            </GridPane>
        </VBox>

        <HBox alignment="CENTER" spacing="20" style="-fx-padding: 10 0 0 0;">
            <Label text="© 2025 Factory Rent Car — Sistema de Gestión de Flota" style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;"/>
        </HBox>
    </VBox>
</ScrollPane>
