<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            style="-fx-background-color: #eef2f8; -fx-background: #eef2f8; -fx-border-color: transparent;"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.factory_rent_car.Controlador.IncidenciaConsultaController">

    <VBox spacing="24" style="-fx-background-color: #eef2f8; -fx-padding: 30 35 35 35;">

        <!-- ═══ ACCESOS RÁPIDOS ═══ -->
        <VBox spacing="12">
            <Label text="Acceso Rápido" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #5a6e8a;"/>
            <GridPane hgap="18" vgap="18" alignment="CENTER">
                <columnConstraints>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                </columnConstraints>

                <VBox fx:id="cardConsultar" spacing="12" alignment="CENTER"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 4); -fx-padding: 20; -fx-cursor: hand;"
                      onMouseClicked="#irAConsultarIncidencias" onMouseEntered="#onCardEnter" onMouseExited="#onCardExit">
                    <Label text="📋" style="-fx-font-size: 36px;"/>
                    <Label text="Consultar Incidencias" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Label text="Ver lista de incidencias" style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
                </VBox>

                <VBox fx:id="cardRegistrar" spacing="12" alignment="CENTER"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 4); -fx-padding: 20; -fx-cursor: hand;"
                      onMouseClicked="#irARegistrarIncidencia" onMouseEntered="#onCardEnter" onMouseExited="#onCardExit">
                    <Label text="⚠️" style="-fx-font-size: 36px;"/>
                    <Label text="Registrar Incidencia" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Label text="Reportar una incidencia" style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
                </VBox>

                <VBox fx:id="cardClientes" spacing="12" alignment="CENTER"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 4); -fx-padding: 20; -fx-cursor: hand;"
                      onMouseClicked="#irAClientes" onMouseEntered="#onCardEnter" onMouseExited="#onCardExit">
                    <Label text="👥" style="-fx-font-size: 36px;"/>
                    <Label text="Clientes" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Label text="Gestionar clientes" style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
                </VBox>

                <VBox fx:id="cardReservas" spacing="12" alignment="CENTER"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 4); -fx-padding: 20; -fx-cursor: hand;"
                      onMouseClicked="#irAReservas" onMouseEntered="#onCardEnter" onMouseExited="#onCardExit">
                    <Label text="🚗" style="-fx-font-size: 36px;"/>
                    <Label text="Reservaciones" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Label text="Administrar reservas" style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
                </VBox>
            </GridPane>
        </VBox>

        <!-- ═══ BARRA DE BÚSQUEDA ═══ -->
        <HBox spacing="12" alignment="CENTER_LEFT"
              style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2); -fx-padding: 14 18;">
            <Label text="🔍" style="-fx-font-size: 16px;"/>
            <TextField fx:id="txtBuscar" promptText="Buscar por tipo, reserva, empleado o estado..." HBox.hgrow="ALWAYS"
                       style="-fx-background-radius: 8; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-padding: 8 14; -fx-font-size: 13px;"/>
            <Button text="Buscar" onAction="#buscar"
                    style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 20; -fx-cursor: hand;"/>
            <Button text="Limpiar" onAction="#limpiarFiltro"
                    style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-background-radius: 8; -fx-padding: 8 20; -fx-cursor: hand; -fx-border-color: #E2E8F0; -fx-border-radius: 8;"/>
        </HBox>

        <!-- ═══ TABLA DE INCIDENCIAS ═══ -->
        <VBox fx:id="tableContainer" spacing="0"
              style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3); -fx-padding: 0;">
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-padding: 16 20; -fx-border-color: transparent transparent #F1F5F9 transparent; -fx-border-width: 0 0 1 0;">
                <Label text="📋" style="-fx-font-size: 16px;"/>
                <Label text="Lista de Incidencias" style="-fx-text-fill: #0F172A; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnToggleTable" text="Ocultar Tabla" onAction="#toggleTableVisibility"
                        style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 6 14; -fx-cursor: hand; -fx-border-color: #E2E8F0; -fx-border-radius: 8;"/>
            </HBox>
            <TableView fx:id="tablaIncidencias" prefHeight="350"
                       style="-fx-background-color: transparent; -fx-border-color: transparent;">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colFecha" text="Fecha" prefWidth="100"/>
                    <TableColumn fx:id="colTipo" text="Tipo" prefWidth="130"/>
                    <TableColumn fx:id="colMonto" text="Monto (RD$)" prefWidth="100"/>
                    <TableColumn fx:id="colDescripcion" text="Descripción" prefWidth="180"/>
                    <TableColumn fx:id="colReserva" text="Reserva" prefWidth="130"/>
                    <TableColumn fx:id="colEmpleado" text="Empleado" prefWidth="130"/>
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                <placeholder>
                    <VBox alignment="CENTER" spacing="8">
                        <Label text="📋" style="-fx-font-size: 32px;"/>
                        <Label text="No hay incidencias registradas" style="-fx-text-fill: #94A3B8; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                    </VBox>
                </placeholder>
            </TableView>
        </VBox>


    </VBox>
</ScrollPane>
