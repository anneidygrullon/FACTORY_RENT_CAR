<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            style="-fx-background-color: #eef2f8; -fx-background: #eef2f8; -fx-border-color: transparent;"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.factory_rent_car.Controlador.IncidenciaRegistroController">

    <VBox spacing="24" style="-fx-background-color: #eef2f8; -fx-padding: 30 35 35 35;">

        <HBox alignment="CENTER_LEFT" spacing="12">
            <StackPane minWidth="32" maxWidth="32" minHeight="32" maxHeight="32"
                       style="-fx-background-color: #1565C0; -fx-background-radius: 8;">
                <Label text="⚠️" style="-fx-font-size: 16px;"/>
            </StackPane>
            <VBox spacing="2">
                <Label text="Registro de Incidencia" style="-fx-text-fill: #0F172A; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Label text="Completa los campos para registrar una nueva incidencia" style="-fx-text-fill: #94A3B8; -fx-font-size: 11px;"/>
            </VBox>
        </HBox>

        <VBox spacing="0"
              style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3);">
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color: #F8FAFC; -fx-background-radius: 14 14 0 0; -fx-padding: 16 20; -fx-border-color: transparent transparent #E2E8F0 transparent; -fx-border-width: 0 0 1 0;">
                <Label text="Datos de la Incidencia" style="-fx-text-fill: #0F172A; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="* Campos obligatorios" style="-fx-text-fill: #94A3B8; -fx-font-size: 10px;"/>
            </HBox>

            <VBox spacing="16" style="-fx-padding: 20 24;">
                <GridPane hgap="12" vgap="12">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="18"/>
                        <ColumnConstraints percentWidth="32"/>
                        <ColumnConstraints percentWidth="18"/>
                        <ColumnConstraints percentWidth="32"/>
                    </columnConstraints>

                    <Label text="Reserva ID *" GridPane.columnIndex="0" GridPane.rowIndex="0"
                           style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <HBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0" alignment="CENTER_LEFT">
                        <TextField fx:id="txtIdReserva" promptText="ID de reserva" prefWidth="130"
                                   style="-fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;"/>
                        <Button text="Buscar" onAction="#buscarReserva"
                                style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 7; -fx-padding: 8 14; -fx-cursor: hand;"/>
                    </HBox>
                    <Label fx:id="lblReservaInfo" GridPane.columnIndex="2" GridPane.rowIndex="0" GridPane.columnSpan="2"
                           style="-fx-text-fill: #1565C0; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 8 0 0 4;"/>

                    <Label text="Empleado ID *" GridPane.columnIndex="0" GridPane.rowIndex="1"
                           style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <HBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="1" alignment="CENTER_LEFT">
                        <TextField fx:id="txtIdEmpleado" promptText="ID de empleado" prefWidth="130"
                                   style="-fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;"/>
                        <Button text="Buscar" onAction="#buscarEmpleado"
                                style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 7; -fx-padding: 8 14; -fx-cursor: hand;"/>
                    </HBox>
                    <Label fx:id="lblEmpleadoInfo" GridPane.columnIndex="2" GridPane.rowIndex="1" GridPane.columnSpan="2"
                           style="-fx-text-fill: #1565C0; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 8 0 0 4;"/>

                    <Label text="Tipo *" GridPane.columnIndex="0" GridPane.rowIndex="2"
                           style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <ComboBox fx:id="cmbTipo" GridPane.columnIndex="1" GridPane.rowIndex="2" promptText="Seleccione tipo" maxWidth="1.7976931348623157E308"/>

                    <Label text="Monto (RD$) *" GridPane.columnIndex="2" GridPane.rowIndex="2"
                           style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtMonto" GridPane.columnIndex="3" GridPane.rowIndex="2" promptText="0.00"
                               style="-fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;"/>

                    <Label text="Fecha *" GridPane.columnIndex="0" GridPane.rowIndex="3"
                           style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <DatePicker fx:id="dpFecha" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                    <Label text="Descripción" GridPane.columnIndex="2" GridPane.rowIndex="3"
                           style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <TextArea fx:id="txtDescripcion" GridPane.columnIndex="3" GridPane.rowIndex="3" prefHeight="80" wrapText="true"
                              style="-fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-font-size: 13px;"/>
                </GridPane>

                <HBox alignment="CENTER_RIGHT" spacing="12" style="-fx-padding: 4 0 0 0;">
                    <Button text="Limpiar" onAction="#limpiar"
                            style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 24; -fx-cursor: hand; -fx-border-color: #E2E8F0; -fx-border-radius: 8;"/>
                    <Button text="Registrar Incidencia" onAction="#registrarIncidencia"
                            style="-fx-background-color: #1565C0; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 32; -fx-cursor: hand;"/>
                </HBox>
            </VBox>
        </VBox>
    </VBox>
</ScrollPane>
