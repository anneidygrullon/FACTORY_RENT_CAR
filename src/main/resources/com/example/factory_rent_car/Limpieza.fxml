<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: #eef2f8; -fx-background: #eef2f8; -fx-border-color: transparent;" vbarPolicy="AS_NEEDED" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.factory_rent_car.Controlador.LimpiezaController">

    <VBox spacing="24" style="-fx-background-color: #eef2f8; -fx-padding: 30 35 35 35;">

        <HBox alignment="CENTER_LEFT" spacing="12">
            <StackPane maxHeight="32" maxWidth="32" minHeight="32" minWidth="32" style="-fx-background-color: #1565C0; -fx-background-radius: 8;">
                <Label style="-fx-font-size: 16px;" />
            </StackPane>
            <VBox spacing="2">
                <Label style="-fx-text-fill: #0F172A; -fx-font-size: 18px; -fx-font-weight: bold;" text="Limpieza de Vehículos" />
                <Label style="-fx-text-fill: #94A3B8; -fx-font-size: 11px;" text="Registra y gestiona las limpiezas de vehículos" />
            </VBox>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2); -fx-padding: 14 18;">
            <Label style="-fx-font-size: 16px;" text="🔍" />
            <TextField fx:id="txtBuscar" promptText="Buscar por vehículo, empleado o tipo..." style="-fx-background-radius: 8; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-padding: 8 14; -fx-font-size: 13px;" HBox.hgrow="ALWAYS" />
            <Button onAction="#buscar" style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 20; -fx-cursor: hand;" text="Buscar" />
            <Button onAction="#limpiarFiltro" style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-background-radius: 8; -fx-padding: 8 20; -fx-cursor: hand; -fx-border-color: #E2E8F0; -fx-border-radius: 8;" text="Limpiar" />
        </HBox>

        <VBox fx:id="tableContainer" spacing="0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3); -fx-padding: 0;">
            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 16 20; -fx-border-color: transparent transparent #F1F5F9 transparent; -fx-border-width: 0 0 1 0;">
                <Label style="-fx-font-size: 16px;" text="📋" />
                <Label style="-fx-text-fill: #0F172A; -fx-font-size: 15px; -fx-font-weight: bold;" text="Lista de Limpiezas" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="btnToggleTable" onAction="#toggleTableVisibility" style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 6 14; -fx-cursor: hand; -fx-border-color: #E2E8F0; -fx-border-radius: 8;" text="Ocultar Tabla" />
            </HBox>
            <TableView fx:id="tablaLimpiezas" prefHeight="300" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="50" text="ID" />
                    <TableColumn fx:id="colFecha" prefWidth="100" text="Fecha" />
                    <TableColumn fx:id="colVehiculo" prefWidth="200" text="Vehículo" />
                    <TableColumn fx:id="colTipo" prefWidth="120" text="Tipo" />
                    <TableColumn fx:id="colObservaciones" prefWidth="250" text="Observaciones" />
                    <TableColumn fx:id="colEmpleado" prefWidth="150" text="Empleado" />
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                <placeholder>
                    <VBox alignment="CENTER" spacing="8">
                        <Label style="-fx-font-size: 32px;" text="📋" />
                        <Label style="-fx-text-fill: #94A3B8; -fx-font-size: 13px; -fx-font-weight: bold;" text="No hay registros de limpieza" />
                    </VBox>
                </placeholder>
            </TableView>
        </VBox>

        <VBox spacing="0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3);">
            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: #F8FAFC; -fx-background-radius: 14 14 0 0; -fx-padding: 16 20; -fx-border-color: transparent transparent #E2E8F0 transparent; -fx-border-width: 0 0 1 0;">
                <StackPane maxHeight="28" maxWidth="28" minHeight="28" minWidth="28" style="-fx-background-color: #1565C0; -fx-background-radius: 7;">
                    <Label style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" text="+" />
                </StackPane>
                <Label fx:id="lblTitulo" style="-fx-text-fill: #0F172A; -fx-font-size: 14px; -fx-font-weight: bold;" text="Registro de Limpieza" />
                <Region HBox.hgrow="ALWAYS" />
                <Label style="-fx-text-fill: #94A3B8; -fx-font-size: 10px;" text="* Campos obligatorios" />
            </HBox>

            <VBox spacing="16" style="-fx-padding: 20 24 20 24;">
                <GridPane hgap="16" vgap="12">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="20" />
                        <ColumnConstraints percentWidth="30" />
                        <ColumnConstraints percentWidth="20" />
                        <ColumnConstraints percentWidth="30" />
                    </columnConstraints>

                    <Label style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;" text="ID Limpieza:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <TextField fx:id="txtIdLimpieza" editable="false" style="-fx-background-color: #F8FAFC; -fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                    <Label style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;" text="ID Vehículo *" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                    <HBox spacing="6" GridPane.columnIndex="3" GridPane.rowIndex="0">
                        <TextField fx:id="txtIdVehiculo" promptText="ID del vehículo" style="-fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;" HBox.hgrow="ALWAYS" />
                        <Button onAction="#buscarVehiculo" style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 7; -fx-padding: 8 14; -fx-cursor: hand;" text="Buscar" />
                    </HBox>

                    <Label style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;" text="Vehículo:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <TextField fx:id="txtVehiculoInfo" editable="false" style="-fx-background-color: #F8FAFC; -fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="1" />

                    <Label style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;" text="ID Empleado *" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <HBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="2">
                        <TextField fx:id="txtIdEmpleado" promptText="ID del empleado" style="-fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;" HBox.hgrow="ALWAYS" />
                        <Button onAction="#buscarEmpleado" style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 7; -fx-padding: 8 14; -fx-cursor: hand;" text="Buscar" />
                    </HBox>
                    <TextField fx:id="txtEmpleadoInfo" editable="false" style="-fx-background-color: #F8FAFC; -fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;" GridPane.columnIndex="3" GridPane.rowIndex="2" />

                    <Label style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;" text="Fecha *" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                    <DatePicker fx:id="dpFecha" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                    <Label style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;" text="Tipo de Limpieza *" GridPane.columnIndex="2" GridPane.rowIndex="3" />
                    <ComboBox fx:id="cmbTipo" maxWidth="1.7976931348623157E308" promptText="Seleccione" GridPane.columnIndex="3" GridPane.rowIndex="3" />

                    <Label style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;" text="Observaciones" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                    <TextArea fx:id="txtObservaciones" prefHeight="80" style="-fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-font-size: 13px;" wrapText="true" GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="4" />
               <rowConstraints>
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
               </rowConstraints>
                </GridPane>

                <HBox alignment="CENTER_RIGHT" spacing="12" style="-fx-padding: 4 0 0 0;">
                <Button onAction="#nuevo" style="-fx-background-color: #2E7D32; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 24; -fx-cursor: hand;" text="Nuevo Registro" />
                <Button onAction="#limpiar" style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 24; -fx-cursor: hand; -fx-border-color: #E2E8F0; -fx-border-radius: 8;" text="Limpiar" />
                <Button onAction="#guardarLimpieza" style="-fx-background-color: #1565C0; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 28; -fx-cursor: hand;" text="Guardar" />
                <Button onAction="#eliminarLimpieza" style="-fx-background-color: #FEF2F2; -fx-text-fill: #DC2626; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 24; -fx-cursor: hand; -fx-border-color: #FECACA; -fx-border-radius: 8;" text="Eliminar" />
                </HBox>
            </VBox>
        </VBox>
    </VBox>
</ScrollPane>
