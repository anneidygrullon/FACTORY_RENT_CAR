                                      onMouseEntered="#onSubMenuEnter" onMouseExited="#onSubMenuExit">
                                    <Label text="➕ Registro de Vehículos" style="-fx-text-fill: #c8d8f0; -fx-font-size: 12px; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                </HBox>
                            </VBox>
                        </VBox>

                        <!-- MANTENIMIENTO -->
                        <HBox fx:id="menuMantenimiento" prefWidth="1e30" spacing="12" alignment="CENTER_LEFT"
                              style="-fx-background-color: transparent; -fx-padding: 10 14 10 16; -fx-cursor: hand; -fx-background-radius: 8;"
                              onMouseClicked="#handleMenuMantenimiento"
                              onMouseEntered="#onMenuEnter" onMouseExited="#onMenuExit">
                            <StackPane minWidth="24" alignment="CENTER">
                                <SVGPath content="M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z"
                                         fill="white" scaleX="0.85" scaleY="0.85"/>
                            </StackPane>
                            <Label text="Mantenimiento" HBox.hgrow="ALWAYS"
                                   style="-fx-font-size: 13px; -fx-text-fill: #c8d8f0; -fx-font-family: 'Segoe UI', sans-serif;"/>
                        </HBox>

                        <!-- LIMPIEZA -->
                        <HBox fx:id="menuLimpieza" prefWidth="1e30" spacing="12" alignment="CENTER_LEFT"
                              style="-fx-background-color: transparent; -fx-padding: 10 14 10 16; -fx-cursor: hand; -fx-background-radius: 8;"
                              onMouseClicked="#handleMenuLimpieza"
                              onMouseEntered="#onMenuEnter" onMouseExited="#onMenuExit">
                            <StackPane minWidth="24" alignment="CENTER">
                                <SVGPath content="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"
                                         fill="white" scaleX="0.85" scaleY="0.85"/>
                            </StackPane>
                            <Label text="Limpieza" HBox.hgrow="ALWAYS"
                                   style="-fx-font-size: 13px; -fx-text-fill: #c8d8f0; -fx-font-family: 'Segoe UI', sans-serif;"/>
                        </HBox>

                        <!-- INCIDENCIAS (submenú) -->
                        <VBox spacing="0">
                            <HBox fx:id="menuIncidencias" prefWidth="1e30" spacing="12" alignment="CENTER_LEFT"
                                  style="-fx-background-color: transparent; -fx-padding: 10 14 10 16; -fx-cursor: hand; -fx-background-radius: 8;"
