                                             fill="white" scaleX="0.85" scaleY="0.85"/>
                                </StackPane>
                                <Label text="Entregas" HBox.hgrow="ALWAYS"
                                       style="-fx-font-size: 13px; -fx-text-fill: #c8d8f0; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                <Label fx:id="entregasArrow" text="❯"
                                       style="-fx-font-size: 10px; -fx-text-fill: #5a7aaa; -fx-font-weight: bold;"/>
                            </HBox>
                            <VBox fx:id="subMenuEntregas" spacing="0" managed="false" visible="false"
                                  style="-fx-background-color: #0a1540; -fx-padding: 2 0 2 36; -fx-background-radius: 0 8 8 0;">
                                <HBox fx:id="subMenuRegistroEntrega" spacing="10" alignment="CENTER_LEFT"
                                      style="-fx-padding: 7 14 7 14; -fx-cursor: hand; -fx-background-radius: 6;"
                                      onMouseClicked="#handleSubMenuRegistroEntrega"
                                      onMouseEntered="#onSubMenuEnter" onMouseExited="#onSubMenuExit">
                                    <Label text="🚚 Registro de Entrega" style="-fx-text-fill: #c8d8f0; -fx-font-size: 12px; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                </HBox>
                                <HBox fx:id="subMenuRegistroDireccion" spacing="10" alignment="CENTER_LEFT"
                                      style="-fx-padding: 7 14 7 14; -fx-cursor: hand; -fx-background-radius: 6;"
                                      onMouseClicked="#handleSubMenuRegistroDireccion"
                                      onMouseEntered="#onSubMenuEnter" onMouseExited="#onSubMenuExit">
                                    <Label text="📍 Registro de Dirección" style="-fx-text-fill: #c8d8f0; -fx-font-size: 12px; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                </HBox>
                            </VBox>
                        </VBox>

                        <!-- DEVOLUCIÓN -->
                        <HBox fx:id="menuDevolucion" prefWidth="1e30" spacing="12" alignment="CENTER_LEFT"
                              style="-fx-background-color: transparent; -fx-padding: 10 14 10 16; -fx-cursor: hand; -fx-background-radius: 8;"
                              onMouseClicked="#handleMenuDevolucion"
                              onMouseEntered="#onMenuEnter" onMouseExited="#onMenuExit">
                            <StackPane minWidth="24" alignment="CENTER">
                                <SVGPath content="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z"
                                         fill="white" scaleX="0.85" scaleY="0.85"/>
                            </StackPane>
                            <Label text="Devolución" HBox.hgrow="ALWAYS"
                                   style="-fx-font-size: 13px; -fx-text-fill: #c8d8f0; -fx-font-family: 'Segoe UI', sans-serif;"/>
                        </HBox>

                        <!-- PAGOS -->
                        <HBox fx:id="menuPagos" prefWidth="1e30" spacing="12" alignment="CENTER_LEFT"
                              style="-fx-background-color: transparent; -fx-padding: 10 14 10 16; -fx-cursor: hand; -fx-background-radius: 8;"
                              onMouseClicked="#handleMenuPagos"
                              onMouseEntered="#onMenuEnter" onMouseExited="#onMenuExit">
                            <StackPane minWidth="24" alignment="CENTER">
                                <SVGPath content="M20 4H4c-1.11 0-1.99.89-1.99 2L2 18c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z"
                                         fill="white" scaleX="0.85" scaleY="0.85"/>
                            </StackPane>
                            <Label text="Pagos" HBox.hgrow="ALWAYS"
                                   style="-fx-font-size: 13px; -fx-text-fill: #c8d8f0; -fx-font-family: 'Segoe UI', sans-serif;"/>
                        </HBox>

                        <!-- VEHÍCULOS (submenú) -->
                        <VBox spacing="0">
                            <HBox fx:id="menuVehiculos" prefWidth="1e30" spacing="12" alignment="CENTER_LEFT"
                                  style="-fx-background-color: transparent; -fx-padding: 10 14 10 16; -fx-cursor: hand; -fx-background-radius: 8;"
                                  onMouseClicked="#toggleSubMenuVehiculos"
                                  onMouseEntered="#onMenuEnter" onMouseExited="#onMenuExit">
                                <StackPane minWidth="24" alignment="CENTER">
                                    <SVGPath content="M18.92 6.01C18.72 5.42 18.16 5 17.5 5h-11c-.66 0-1.21.42-1.42 1.01L3 12v8c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1h12v1c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-8l-2.08-5.99zM6.5 16c-.83 0-1.5-.67-1.5-1.5S5.67 13 6.5 13s1.5.67 1.5 1.5S7.33 16 6.5 16zm11 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zM5 11l1.5-4.5h11L19 11H5z"
                                             fill="white" scaleX="0.85" scaleY="0.85"/>
                                </StackPane>
                                <Label text="Vehículos" HBox.hgrow="ALWAYS"
                                       style="-fx-font-size: 13px; -fx-text-fill: #c8d8f0; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                <Label fx:id="vehiculosArrow" text="❯"
                                       style="-fx-font-size: 10px; -fx-text-fill: #5a7aaa; -fx-font-weight: bold;"/>
                            </HBox>
                            <VBox fx:id="subMenuVehiculos" spacing="0" managed="false" visible="false"
                                  style="-fx-background-color: #0a1540; -fx-padding: 2 0 2 36; -fx-background-radius: 0 8 8 0;">
                                <HBox fx:id="subMenuVehiculoConsulta" spacing="10" alignment="CENTER_LEFT"
                                      style="-fx-padding: 7 14 7 14; -fx-cursor: hand; -fx-background-radius: 6;"
                                      onMouseClicked="#handleSubMenuVehiculoConsulta"
                                      onMouseEntered="#onSubMenuEnter" onMouseExited="#onSubMenuExit">
                                    <Label text="📋 Consulta de Vehículos" style="-fx-text-fill: #c8d8f0; -fx-font-size: 12px; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                </HBox>
                                <HBox fx:id="subMenuVehiculoRegistro" spacing="10" alignment="CENTER_LEFT"
