<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.factory_rent_car.Controlador.MainLayoutController"
            prefWidth="1100" prefHeight="700">

    <!-- TOP BAR -->
    <top>
        <HBox prefHeight="60" alignment="CENTER_LEFT"
              style="-fx-background-color: #0d0d1a;
                     -fx-border-color: transparent transparent #1a3a7c transparent;
                     -fx-border-width: 0 0 1 0;
                     -fx-padding: 0 20 0 24;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.6), 8, 0, 0, 3);">

            <HBox alignment="CENTER_LEFT" spacing="12" HBox.hgrow="ALWAYS">
                <SVGPath content="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"
                         fill="#4a9eff" scaleX="1.1" scaleY="1.1"/>
                <Label fx:id="sectionTitle" text="Inicio"
                       style="-fx-font-size: 18px; -fx-font-weight: 600;
                              -fx-font-style: italic; -fx-text-fill: white;
                              -fx-font-family: 'Segoe UI', sans-serif;"/>
            </HBox>

            <HBox alignment="CENTER_RIGHT" spacing="8">
                <StackPane style="-fx-cursor: hand; -fx-padding: 6; -fx-background-radius: 8; -fx-background-color: rgba(255,255,255,0.05);"
                           onMouseEntered="#onNotificationEnter" onMouseExited="#onNotificationExit">
                    <SVGPath content="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.9 2 2 2zm6-6v-5c0-3.07-1.64-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.63 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z"
                             fill="#8aa0cc" scaleX="0.85" scaleY="0.85"/>
                    <Circle radius="4" fill="#ff6b6b" translateX="8" translateY="-8"/>
                </StackPane>

                <Region prefWidth="1" prefHeight="28" style="-fx-background-color: rgba(255,255,255,0.08); -fx-background-radius: 2;"/>

                <HBox fx:id="userArea" alignment="CENTER" spacing="10"
                      style="-fx-cursor: hand; -fx-padding: 4 8 4 4; -fx-background-radius: 10; -fx-background-color: rgba(255,255,255,0.04);"
                      onMouseClicked="#handleUserMenu"
                      onMouseEntered="#onUserAreaEnter" onMouseExited="#onUserAreaExit">
                    <StackPane>
                        <Circle radius="20" fill="#1b3264" stroke="#3a5898" strokeWidth="2"/>
                        <Circle radius="20" fill="transparent" stroke="#4a9eff" strokeWidth="1" opacity="0.4"/>
                        <ImageView fx:id="profileImageView" fitWidth="36" fitHeight="36"
                                   preserveRatio="true" pickOnBounds="true"/>
                    </StackPane>
                    <VBox alignment="CENTER_LEFT" spacing="1">
                        <Label fx:id="lblRol" text="Administrador"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white; -fx-font-family: 'Segoe UI', sans-serif;"/>
                        <Label fx:id="lblUsuario" text=""
                               style="-fx-font-size: 11px; -fx-text-fill: #8aa0cc; -fx-font-family: 'Segoe UI', sans-serif;"/>
                    </VBox>
                    <SVGPath content="M7 10l5 5 5-5z" fill="#6a8aaa"
                             style="-fx-cursor: hand;"/>
                </HBox>

                <StackPane style="-fx-cursor: hand; -fx-padding: 6; -fx-background-radius: 8; -fx-background-color: rgba(255,255,255,0.05);"
                           onMouseClicked="#handleLogout"
                           onMouseEntered="#onLogoutEnter" onMouseExited="#onLogoutExit">
                    <SVGPath content="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z"
                             fill="#ff6b6b" scaleX="0.85" scaleY="0.85"/>
                </StackPane>
            </HBox>
        </HBox>
    </top>

    <!-- SIDEBAR -->
    <left>
        <VBox prefWidth="248"
              style="-fx-background-color: #112060;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 8, 0, 2, 0);">

            <!-- LOGO -->
            <VBox alignment="CENTER" spacing="4"
                  style="-fx-background-color: #0a1540;
                         -fx-padding: 18 16 14 16;
                         -fx-border-color: transparent transparent rgba(255,255,255,0.06) transparent;
                         -fx-border-width: 0 0 1 0;">
                <StackPane>
                    <SVGPath content="M18.92 6.01C18.72 5.42 18.16 5 17.5 5h-11c-.66 0-1.21.42-1.42 1.01L3 12v8c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1h12v1c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-8l-2.08-5.99zM6.5 16c-.83 0-1.5-.67-1.5-1.5S5.67 13 6.5 13s1.5.67 1.5 1.5S7.33 16 6.5 16zm11 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zM5 11l1.5-4.5h11L19 11H5z"
                             fill="white" scaleX="1.5" scaleY="1.5"/>
                </StackPane>
                <Label text="FACTORY"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white; -fx-font-family: 'Segoe UI', sans-serif;
                              -fx-letter-spacing: 2;"/>
                <HBox alignment="CENTER" spacing="8">
                    <Line startX="0" endX="20" startY="0" endY="0"
                          style="-fx-stroke: #2a5acc; -fx-stroke-width: 1.2;"/>
                    <Label text="RENT CAR"
                           style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #4a9eff; -fx-font-family: 'Segoe UI', sans-serif;
                                  -fx-letter-spacing: 1;"/>
                    <Line startX="0" endX="20" startY="0" endY="0"
                          style="-fx-stroke: #2a5acc; -fx-stroke-width: 1.2;"/>
                </HBox>
            </VBox>

            <!-- INICIO -->
            <HBox fx:id="menuInicio" prefWidth="1e30" spacing="12" alignment="CENTER_LEFT"
                  style="-fx-background-color: #0a1540;
                         -fx-border-color: transparent transparent transparent #4a9eff;
                         -fx-border-width: 0 0 0 3;
                         -fx-padding: 12 14 12 14;
                         -fx-cursor: hand;
                         -fx-background-radius: 0 8 8 0;"
                  onMouseClicked="#handleMenuInicio">
                <StackPane minWidth="22" alignment="CENTER">
                    <SVGPath content="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"
                             fill="white" scaleX="1.0" scaleY="1.0"/>
                </StackPane>
                <Label text="Inicio" HBox.hgrow="ALWAYS"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white; -fx-font-family: 'Segoe UI', sans-serif;"/>
                <Circle radius="5" fill="#4a9eff" opacity="0.8"/>
            </HBox>

            <Region prefHeight="1" style="-fx-background-color: rgba(255,255,255,0.05); -fx-padding: 0 16 0 16;"/>

            <!-- SCROLL PARA EL MENÚ PRINCIPAL -->
            <ScrollPane fitToWidth="true" vbarPolicy="AS_NEEDED" hbarPolicy="NEVER" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                <VBox style="-fx-background-color: #112060;">
                    <VBox spacing="1">

                        <!-- RESERVACIÓN (submenú) -->
                        <VBox spacing="0">
                            <HBox fx:id="menuReservacion" prefWidth="1e30" spacing="12" alignment="CENTER_LEFT"
                                  style="-fx-background-color: transparent; -fx-padding: 10 14 10 16; -fx-cursor: hand; -fx-background-radius: 8;"
                                  onMouseClicked="#toggleSubMenuReservacion"
                                  onMouseEntered="#onMenuEnter" onMouseExited="#onMenuExit">
                                <StackPane minWidth="24" alignment="CENTER">
                                    <SVGPath content="M17 12h-5v5h5v-5zM16 1v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-1V1h-2zm3 18H5V8h14v11z"
                                             fill="white" scaleX="0.85" scaleY="0.85"/>
                                </StackPane>
                                <Label text="Reservación" HBox.hgrow="ALWAYS"
                                       style="-fx-font-size: 13px; -fx-text-fill: #c8d8f0; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                <Label fx:id="reservacionArrow" text="❯"
                                       style="-fx-font-size: 10px; -fx-text-fill: #5a7aaa; -fx-font-weight: bold;"/>
                            </HBox>
                            <VBox fx:id="subMenuReservacion" spacing="0" managed="false" visible="false"
                                  style="-fx-background-color: #0a1540; -fx-padding: 2 0 2 36; -fx-background-radius: 0 8 8 0;">
                                <HBox fx:id="subMenuReservaVehiculo" spacing="10" alignment="CENTER_LEFT"
                                      style="-fx-padding: 7 14 7 14; -fx-cursor: hand; -fx-background-radius: 6;"
                                      onMouseClicked="#handleSubMenuReservaVehiculo"
                                      onMouseEntered="#onSubMenuEnter" onMouseExited="#onSubMenuExit">
                                    <Label text="🚗 Reserva de Vehículos" style="-fx-text-fill: #c8d8f0; -fx-font-size: 12px; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                </HBox>
                                <HBox fx:id="subMenuReservaObjeto" spacing="10" alignment="CENTER_LEFT"
                                      style="-fx-padding: 7 14 7 14; -fx-cursor: hand; -fx-background-radius: 6;"
                                      onMouseClicked="#handleSubMenuReservaObjeto"
                                      onMouseEntered="#onSubMenuEnter" onMouseExited="#onSubMenuExit">
                                    <Label text="📦 Reserva de Objetos" style="-fx-text-fill: #c8d8f0; -fx-font-size: 12px; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                </HBox>
                            </VBox>
                        </VBox>

                        <!-- ENTREGAS (submenú) -->
                        <VBox spacing="0">
                            <HBox fx:id="menuEntregas" prefWidth="1e30" spacing="12" alignment="CENTER_LEFT"
