                                  onMouseEntered="#onMenuEnter" onMouseExited="#onMenuExit">
                                <StackPane minWidth="24" alignment="CENTER">
                                    <SVGPath content="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"
                                             fill="white" scaleX="0.85" scaleY="0.85"/>
                                </StackPane>
                                <Label text="Incidencias" HBox.hgrow="ALWAYS"
                                       style="-fx-font-size: 13px; -fx-text-fill: #c8d8f0; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                <Label fx:id="incidenciasArrow" text="❯"
                                       style="-fx-font-size: 10px; -fx-text-fill: #5a7aaa; -fx-font-weight: bold;"/>
                            </HBox>
                            <VBox fx:id="subMenuIncidencias" spacing="0" managed="false" visible="false"
                                  style="-fx-background-color: #0a1540; -fx-padding: 2 0 2 36; -fx-background-radius: 0 8 8 0;">
                                <HBox fx:id="subMenuIncidenciaConsulta" spacing="10" alignment="CENTER_LEFT"
                                      style="-fx-padding: 7 14 7 14; -fx-cursor: hand; -fx-background-radius: 6;"
                                      onMouseClicked="#handleSubMenuIncidenciaConsulta"
                                      onMouseEntered="#onSubMenuEnter" onMouseExited="#onSubMenuExit">
                                    <Label text="📋 Consulta de Incidencias" style="-fx-text-fill: #c8d8f0; -fx-font-size: 12px; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                </HBox>
                                <HBox fx:id="subMenuIncidenciaRegistro" spacing="10" alignment="CENTER_LEFT"
                                      style="-fx-padding: 7 14 7 14; -fx-cursor: hand; -fx-background-radius: 6;"
                                      onMouseClicked="#handleSubMenuIncidenciaRegistro"
                                      onMouseEntered="#onSubMenuEnter" onMouseExited="#onSubMenuExit">
                                    <Label text="➕ Registro de Incidencia" style="-fx-text-fill: #c8d8f0; -fx-font-size: 12px; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                </HBox>
                            </VBox>
                        </VBox>

                        <!-- COMPRAS (submenú) -->
                        <VBox spacing="0">
                            <HBox fx:id="menuCompras" prefWidth="1e30" spacing="12" alignment="CENTER_LEFT"
                                  style="-fx-background-color: transparent; -fx-padding: 10 14 10 16; -fx-cursor: hand; -fx-background-radius: 8;"
                                  onMouseClicked="#toggleSubMenuCompras"
                                  onMouseEntered="#onMenuEnter" onMouseExited="#onMenuExit">
                                <StackPane minWidth="24" alignment="CENTER">
                                    <SVGPath content="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96C5 16.1 6.9 18 9 18h12v-2H9.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63H19c.75 0 1.41-.41 1.75-1.03l3.58-6.49A1 1 0 0023.45 5H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"
                                             fill="white" scaleX="0.85" scaleY="0.85"/>
                                </StackPane>
                                <Label text="Compras" HBox.hgrow="ALWAYS"
