<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.factory_rent_car.Controlador.MantenimientoController"
            style="-fx-background-color: #F8FAFC; -fx-background: #F8FAFC; -fx-border-color: transparent;">

    <VBox spacing="16" style="-fx-background-color: #F8FAFC; -fx-padding: 20;">

        <!-- Barra de búsqueda -->
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label text="Buscar:" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
            <TextField fx:id="txtBuscar" promptText="Vehículo, tipo, descripción..." HBox.hgrow="ALWAYS"
                       style="-fx-background-radius: 6; -fx-border-color: #E2E8F0; -fx-border-radius: 6; -fx-padding: 6 10;"/>
            <Button text="Buscar" onAction="#buscar"
                    style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 6 16;"/>
            <Button text="Limpiar filtro" onAction="#limpiarFiltro"
                    style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-background-radius: 6; -fx-padding: 6 16;"/>
        </HBox>

        <!-- Tabla de mantenimientos (ocultable) -->
        <VBox fx:id="tableContainer" spacing="8" style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12;">
            <HBox alignment="CENTER_LEFT">
                <Label text="Lista de Mantenimientos" style="-fx-text-fill: #0F172A; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnToggleTable" text="📋 Ocultar Tabla" onAction="#toggleTableVisibility"
                        style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-font-size: 11px; -fx-background-radius: 6; -fx-padding: 4 12; -fx-cursor: hand;"/>
            </HBox>
            <TableView fx:id="tablaMantenimientos" prefHeight="350">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colVehiculo" text="Vehículo" prefWidth="180"/>
                    <TableColumn fx:id="colTipo" text="Tipo" prefWidth="150"/>
                    <TableColumn fx:id="colFechaIngreso" text="Fec. Ingreso" prefWidth="110"/>
                    <TableColumn fx:id="colFechaSalida" text="Fec. Salida" prefWidth="110"/>
                    <TableColumn fx:id="colDias" text="Días" prefWidth="60"/>
                    <TableColumn fx:id="colCosto" text="Costo (RD$)" prefWidth="120"/>
                    <TableColumn fx:id="colDescripcion" text="Descripción" prefWidth="250"/>
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                <placeholder><Label text="No hay registros de mantenimiento"/></placeholder>
            </TableView>
        </VBox>

        <!-- Formulario de registro / edición -->
        <VBox spacing="12" style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 16;">
            <Label fx:id="lblTitulo" text="Registro de Mantenimiento" style="-fx-text-fill: #0F172A; -fx-font-size: 14px; -fx-font-weight: bold;"/>

            <GridPane hgap="12" vgap="10">
                <columnConstraints>
                    <ColumnConstraints percentWidth="20"/>
                    <ColumnConstraints percentWidth="30"/>
                    <ColumnConstraints percentWidth="20"/>
                    <ColumnConstraints percentWidth="30"/>
                </columnConstraints>

                <Label text="ID Mantenimiento:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextField fx:id="txtIdMantenimiento" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="ID Vehículo *" GridPane.columnIndex="2" GridPane.rowIndex="0" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <HBox spacing="6" GridPane.columnIndex="3" GridPane.rowIndex="0">
                    <TextField fx:id="txtIdVehiculo" promptText="ID del vehículo" HBox.hgrow="ALWAYS"/>
                    <Button text="Buscar" onAction="#buscarVehiculo"
                            style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 4 10;"/>
                </HBox>

                <Label text="Vehículo:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextField fx:id="txtVehiculoInfo" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="1" GridPane.columnSpan="3"/>

                <Label text="Fecha Ingreso *" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <DatePicker fx:id="dpFechaIngreso" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                <Label text="Fecha Salida *" GridPane.columnIndex="2" GridPane.rowIndex="2" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <DatePicker fx:id="dpFechaSalida" GridPane.columnIndex="3" GridPane.rowIndex="2"/>

                <Label text="Días de taller:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextField fx:id="txtDias" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                <Label text="Costo (RD$) *" GridPane.columnIndex="2" GridPane.rowIndex="3" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextField fx:id="txtCosto" GridPane.columnIndex="3" GridPane.rowIndex="3" promptText="0.00"/>

                <Label text="Descripción *" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextArea fx:id="txtDescripcion" GridPane.columnIndex="1" GridPane.rowIndex="4" GridPane.columnSpan="3" prefHeight="80" wrapText="true"/>
            </GridPane>

            <!-- RadioButtons para Tipo -->
            <VBox spacing="6">
                <Label text="Tipo de Mantenimiento *" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <HBox spacing="20" alignment="CENTER_LEFT">
                    <RadioButton fx:id="rbMotivo" text="Motivo de mantenimiento"/>
                    <RadioButton fx:id="rbIncidencia" text="Incidencia"/>
                    <RadioButton fx:id="rbRevision" text="Revisión"/>
                    <RadioButton fx:id="rbGarantia" text="Garantía"/>
                    <RadioButton fx:id="rbDiagnostico" text="Diagnóstico preventivo"/>
                </HBox>
            </VBox>

            <HBox alignment="CENTER_RIGHT" spacing="12">
                <Button text="Limpiar" onAction="#limpiar"
                        style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-background-radius: 6; -fx-padding: 8 20;"/>
                <Button text="Guardar" onAction="#guardarMantenimiento"
                        style="-fx-background-color: #1565C0; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 8 28;"/>
                <Button text="Eliminar" onAction="#eliminarMantenimiento"
                        style="-fx-background-color: #FEF2F2; -fx-text-fill: #DC2626; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 8 20;"/>
            </HBox>
        </VBox>
    </VBox>
</ScrollPane>