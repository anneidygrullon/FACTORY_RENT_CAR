<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.factory_rent_car.Controlador.NotaCreditoController"
            style="-fx-background-color: #eef2f8; -fx-background: #eef2f8; -fx-border-color: transparent;">
    <VBox spacing="24" style="-fx-background-color: #eef2f8; -fx-padding: 30;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <StackPane minWidth="32" maxWidth="32" minHeight="32" maxHeight="32"
                   style="-fx-background-color: #1565C0; -fx-background-radius: 8;">
            <Label text="&#128203;" style="-fx-font-size: 16px;"/>
        </StackPane>
        <VBox spacing="2">
            <Label text="Notas de Crédito" style="-fx-text-fill: #0F172A; -fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Label text="Gestión de notas de crédito por devolución anticipada" style="-fx-text-fill: #94A3B8; -fx-font-size: 11px;"/>
        </VBox>
    </HBox>

    <!-- Quick-access cards row -->
    <HBox spacing="20">
        <StackPane onMouseClicked="#irAConsultaPagos"
                   style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2); -fx-padding: 16 20; -fx-cursor: hand;"
                   HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="&#128176;" style="-fx-font-size: 20px;"/>
                <Label text="Consulta de Pagos" style="-fx-text-fill: #475569; -fx-font-size: 13px; -fx-font-weight: bold;"/>
            </HBox>
        </StackPane>
        <StackPane onMouseClicked="#irARegistroPago"
                   style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2); -fx-padding: 16 20; -fx-cursor: hand;"
                   HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="&#128179;" style="-fx-font-size: 20px;"/>
                <Label text="Registrar Pago" style="-fx-text-fill: #475569; -fx-font-size: 13px; -fx-font-weight: bold;"/>
            </HBox>
        </StackPane>
        <StackPane fx:id="cardNotasCredito"
                   style="-fx-background-color: #1565C0; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2); -fx-padding: 16 20; -fx-cursor: hand;"
                   HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="&#128203;" style="-fx-font-size: 20px;"/>
                <Label text="Notas de Crédito" style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
            </HBox>
        </StackPane>
    </HBox>

    <!-- Table card -->
    <VBox fx:id="tableContainerNotas" spacing="0"
          style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3); -fx-padding: 0;">
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-padding: 16 20; -fx-border-color: transparent transparent #F1F5F9 transparent; -fx-border-width: 0 0 1 0;">
            <Label text="&#128203;" style="-fx-font-size: 16px;"/>
            <Label text="Notas de Crédito Registradas" style="-fx-text-fill: #0F172A; -fx-font-size: 15px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnToggleTableNotas" text="Ocultar Tabla" onAction="#toggleTableNotasVisibility"
                    style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 6 14; -fx-cursor: hand; -fx-border-color: #E2E8F0; -fx-border-radius: 8;"/>
        </HBox>
        <TableView fx:id="tablaNotasCredito" prefHeight="250"
                   style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <columns>
                <TableColumn fx:id="colIdNota" text="ID" prefWidth="60"/>
                <TableColumn fx:id="colFechaNota" text="Fecha" prefWidth="100"/>
                <TableColumn fx:id="colClienteNota" text="Cliente" prefWidth="160"/>
                <TableColumn fx:id="colReservaNota" text="Reserva" prefWidth="100"/>
                <TableColumn fx:id="colMontoNota" text="Monto RD$" prefWidth="100"/>
                <TableColumn fx:id="colMotivoNota" text="Motivo" prefWidth="140"/>
                <TableColumn fx:id="colUsadoNota" text="Usado" prefWidth="70"/>
            </columns>
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
            <placeholder>
                <VBox alignment="CENTER" spacing="8">
                    <Label text="&#128203;" style="-fx-font-size: 32px;"/>
                    <Label text="No hay notas de crédito registradas" style="-fx-text-fill: #94A3B8; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                </VBox>
            </placeholder>
        </TableView>
    </VBox>

    <!-- Form card: Registrar Nota de Crédito por Devolución Anticipada -->
    <VBox spacing="0"
          style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3);">
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: #F8FAFC; -fx-background-radius: 14 14 0 0; -fx-padding: 16 20; -fx-border-color: transparent transparent #E2E8F0 transparent; -fx-border-width: 0 0 1 0;">
            <StackPane minWidth="28" maxWidth="28" minHeight="28" maxHeight="28"
                       style="-fx-background-color: #2E7D32; -fx-background-radius: 7;">
                <Label text="&#128203;" style="-fx-font-size: 14px;"/>
            </StackPane>
            <Label text="Registrar Nota de Crédito por Devolución Anticipada" style="-fx-text-fill: #0F172A; -fx-font-size: 14px; -fx-font-weight: bold;"/>
        </HBox>

        <VBox spacing="16" style="-fx-padding: 20 24 20 24;">
            <GridPane hgap="16" vgap="12">
                <columnConstraints>
                    <ColumnConstraints percentWidth="18"/>
                    <ColumnConstraints percentWidth="32"/>
                    <ColumnConstraints percentWidth="18"/>
                    <ColumnConstraints percentWidth="32"/>
                </columnConstraints>

                <Label text="Reserva ID" GridPane.columnIndex="0" GridPane.rowIndex="0"
                       style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                <HBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <TextField fx:id="txtReservaIdNota" promptText="ID de reserva" HBox.hgrow="ALWAYS"
                               style="-fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;"/>
                    <Button text="Buscar" onAction="#buscarReservaNota"
                            style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 7; -fx-padding: 8 14; -fx-cursor: hand;"/>
                </HBox>

                <Label text="Cliente:" GridPane.columnIndex="2" GridPane.rowIndex="0"
                       style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                <TextField fx:id="txtClienteNota" editable="false" GridPane.columnIndex="3" GridPane.rowIndex="0"
                           style="-fx-background-color: #F8FAFC; -fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;"/>

                <Label text="Total Pagado:" GridPane.columnIndex="0" GridPane.rowIndex="1"
                       style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                <TextField fx:id="txtTotalPagado" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="1"
                           style="-fx-background-color: #F8FAFC; -fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;"/>

                <Label text="Días No Usados:" GridPane.columnIndex="2" GridPane.rowIndex="1"
                       style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                <TextField fx:id="txtDiasNoUsados" editable="false" GridPane.columnIndex="3" GridPane.rowIndex="1"
                           style="-fx-background-color: #F8FAFC; -fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;"/>

                <Label text="Monto a Acreditar:" GridPane.columnIndex="0" GridPane.rowIndex="2"
                       style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                <TextField fx:id="txtMontoCredito" editable="false" promptText="Monto a acreditar" GridPane.columnIndex="1" GridPane.rowIndex="2"
                           style="-fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;"/>

                <Label text="Motivo:" GridPane.columnIndex="2" GridPane.rowIndex="2"
                       style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                <TextField fx:id="txtMotivoCredito" promptText="Ej: Devolución anticipada" GridPane.columnIndex="3" GridPane.rowIndex="2"
                           style="-fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;"/>
            </GridPane>

            <HBox alignment="CENTER_RIGHT" spacing="12" style="-fx-padding: 4 0 0 0;">
                <Button text="Limpiar" onAction="#limpiarNota"
                        style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 24; -fx-cursor: hand; -fx-border-color: #E2E8F0; -fx-border-radius: 8;"/>
                <Button text="Crear Nota de Crédito" onAction="#crearNotaCredito"
                        style="-fx-background-color: #2E7D32; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 32; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </VBox>
</VBox>
</ScrollPane>
