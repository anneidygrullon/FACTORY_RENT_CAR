<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.factory_rent_car.Controlador.PagoController"
            style="-fx-background-color: #eef2f8; -fx-background: #eef2f8; -fx-border-color: transparent;">

    <VBox spacing="24" style="-fx-background-color: #eef2f8; -fx-padding: 30 35 35 35;">

        <!-- Título -->
        <HBox alignment="CENTER_LEFT" spacing="12">
            <StackPane minWidth="32" maxWidth="32" minHeight="32" maxHeight="32"
                       style="-fx-background-color: #1565C0; -fx-background-radius: 8;">
                <Label text="💰" style="-fx-font-size: 16px;"/>
            </StackPane>
            <VBox spacing="2">
                <Label text="Pagos" style="-fx-text-fill: #0F172A; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Label text="Administra los pagos y notas de crédito" style="-fx-text-fill: #94A3B8; -fx-font-size: 11px;"/>
            </VBox>
        </HBox>

        <!-- Barra de búsqueda -->
        <HBox spacing="12" alignment="CENTER_LEFT"
              style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2); -fx-padding: 14 18;">
            <Label text="🔍" style="-fx-font-size: 16px;"/>
            <TextField fx:id="txtBuscar" promptText="Buscar por cliente, reserva o método de pago..." HBox.hgrow="ALWAYS"
                       style="-fx-background-radius: 8; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-padding: 8 14; -fx-font-size: 13px;"/>
            <Button text="Buscar" onAction="#buscar"
                    style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 20; -fx-cursor: hand;"/>
            <Button text="Limpiar" onAction="#limpiarFiltro"
                    style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-background-radius: 8; -fx-padding: 8 20; -fx-cursor: hand; -fx-border-color: #E2E8F0; -fx-border-radius: 8;"/>
        </HBox>

        <!-- Tabla de Pagos -->
        <VBox fx:id="tableContainerPagos" spacing="0"
              style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3); -fx-padding: 0;">
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-padding: 16 20; -fx-border-color: transparent transparent #F1F5F9 transparent; -fx-border-width: 0 0 1 0;">
                <Label text="📋" style="-fx-font-size: 16px;"/>
                <Label text="Historial de Pagos" style="-fx-text-fill: #0F172A; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnToggleTablePagos" text="Ocultar Tabla" onAction="#toggleTablePagosVisibility"
                        style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 6 14; -fx-cursor: hand; -fx-border-color: #E2E8F0; -fx-border-radius: 8;"/>
            </HBox>
            <TableView fx:id="tablaPagos" prefHeight="250"
                       style="-fx-background-color: transparent; -fx-border-color: transparent;">
                <columns>
                    <TableColumn fx:id="colIdPago" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colFechaPago" text="Fecha" prefWidth="100"/>
                    <TableColumn fx:id="colClientePago" text="Cliente" prefWidth="180"/>
                    <TableColumn fx:id="colReservaPago" text="Reserva" prefWidth="120"/>
                    <TableColumn fx:id="colMetodoPago" text="Método" prefWidth="120"/>
                    <TableColumn fx:id="colCuentaPago" text="Cuenta" prefWidth="150"/>
                    <TableColumn fx:id="colMontoPago" text="Monto (RD$)" prefWidth="120"/>
                    <TableColumn fx:id="colTipoPago" text="Tipo" prefWidth="100"/>
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                <placeholder>
                    <VBox alignment="CENTER" spacing="8">
                        <Label text="📋" style="-fx-font-size: 32px;"/>
                        <Label text="No hay registros de pagos" style="-fx-text-fill: #94A3B8; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                    </VBox>
                </placeholder>
            </TableView>
        </VBox>

        <!-- Tabla de Notas de Crédito -->
        <VBox fx:id="tableContainerNotas" spacing="0"
              style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3); -fx-padding: 0;">
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-padding: 16 20; -fx-border-color: transparent transparent #F1F5F9 transparent; -fx-border-width: 0 0 1 0;">
                <Label text="📋" style="-fx-font-size: 16px;"/>
                <Label text="Notas de Crédito Disponibles" style="-fx-text-fill: #0F172A; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnToggleTableNotas" text="Ocultar Tabla" onAction="#toggleTableNotasVisibility"
                        style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 6 14; -fx-cursor: hand; -fx-border-color: #E2E8F0; -fx-border-radius: 8;"/>
            </HBox>
            <TableView fx:id="tablaNotasCredito" prefHeight="200"
                       style="-fx-background-color: transparent; -fx-border-color: transparent;">
                <columns>
                    <TableColumn fx:id="colIdNota" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colFechaNota" text="Fecha" prefWidth="100"/>
                    <TableColumn fx:id="colClienteNota" text="Cliente" prefWidth="180"/>
                    <TableColumn fx:id="colReservaNota" text="Reserva" prefWidth="120"/>
                    <TableColumn fx:id="colMontoNota" text="Monto (RD$)" prefWidth="120"/>
                    <TableColumn fx:id="colMotivoNota" text="Motivo" prefWidth="150"/>
                    <TableColumn fx:id="colUsadoNota" text="Usado" prefWidth="80"/>
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                <placeholder>
                    <VBox alignment="CENTER" spacing="8">
                        <Label text="📋" style="-fx-font-size: 32px;"/>
                        <Label text="No hay notas de crédito" style="-fx-text-fill: #94A3B8; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                    </VBox>
                </placeholder>
            </TableView>
        </VBox>

        <!-- Formulario: Registrar Nuevo Pago -->
        <VBox spacing="0"
              style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3);">
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color: #F8FAFC; -fx-background-radius: 14 14 0 0; -fx-padding: 16 20; -fx-border-color: transparent transparent #E2E8F0 transparent; -fx-border-width: 0 0 1 0;">
                <StackPane minWidth="28" maxWidth="28" minHeight="28" maxHeight="28"
                           style="-fx-background-color: #1565C0; -fx-background-radius: 7;">
                    <Label text="+" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                </StackPane>
                <Label text="Registrar Nuevo Pago" style="-fx-text-fill: #0F172A; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="* Campos obligatorios" style="-fx-text-fill: #94A3B8; -fx-font-size: 10px;"/>
            </HBox>

            <VBox spacing="16" style="-fx-padding: 20 24 20 24;">
                <GridPane hgap="16" vgap="12">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="20"/>
                        <ColumnConstraints percentWidth="30"/>
                        <ColumnConstraints percentWidth="20"/>
                        <ColumnConstraints percentWidth="30"/>
                    </columnConstraints>

                    <Label text="Reserva ID *" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <HBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <TextField fx:id="txtReservaId" promptText="ID de reserva" HBox.hgrow="ALWAYS"
                                   style="-fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;"/>
                        <Button text="Buscar" onAction="#buscarReserva"
                                style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 7; -fx-padding: 8 14; -fx-cursor: hand;"/>
                    </HBox>

                    <Label text="Cliente:" GridPane.columnIndex="2" GridPane.rowIndex="0" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtCliente" editable="false" GridPane.columnIndex="3" GridPane.rowIndex="0"
                               style="-fx-background-color: #F8FAFC; -fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;"/>

                    <Label text="Monto Total:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtMontoTotal" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="1"
                               style="-fx-background-color: #F8FAFC; -fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;"/>

                    <Label text="Monto Pagado:" GridPane.columnIndex="2" GridPane.rowIndex="1" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtMontoPagado" editable="false" GridPane.columnIndex="3" GridPane.rowIndex="1"
                               style="-fx-background-color: #F8FAFC; -fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;"/>

                    <Label text="Monto Pendiente:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtMontoPendiente" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="2"
                               style="-fx-background-color: #F8FAFC; -fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;"/>

                    <Label text="Notas de Crédito Disp.:" GridPane.columnIndex="2" GridPane.rowIndex="2" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtNotasDisponibles" editable="false" GridPane.columnIndex="3" GridPane.rowIndex="2"
                               style="-fx-background-color: #F8FAFC; -fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;"/>

                    <Label text="Aplicar Nota de Crédito:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <ComboBox fx:id="cmbNotaCredito" GridPane.columnIndex="1" GridPane.rowIndex="3" promptText="Seleccione nota" maxWidth="1.7976931348623157E308"/>

                    <Label text="Monto a Pagar:" GridPane.columnIndex="2" GridPane.rowIndex="3" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtMontoAPagar" promptText="0.00" GridPane.columnIndex="3" GridPane.rowIndex="3"
                               style="-fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;"/>

                    <Label text="Método de Pago *" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <ComboBox fx:id="cmbMetodoPago" GridPane.columnIndex="1" GridPane.rowIndex="4" promptText="Seleccione" maxWidth="1.7976931348623157E308"/>

                    <Label text="Cuenta Bancaria *" GridPane.columnIndex="2" GridPane.rowIndex="4" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <ComboBox fx:id="cmbCuenta" GridPane.columnIndex="3" GridPane.rowIndex="4" promptText="Seleccione" maxWidth="1.7976931348623157E308"/>
                </GridPane>

                <HBox alignment="CENTER_RIGHT" spacing="12" style="-fx-padding: 4 0 0 0;">
                    <Button text="Limpiar" onAction="#limpiar"
                            style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 24; -fx-cursor: hand; -fx-border-color: #E2E8F0; -fx-border-radius: 8;"/>
                    <Button text="Registrar Pago" onAction="#registrarPago"
                            style="-fx-background-color: #1565C0; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 32; -fx-cursor: hand;"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- Formulario: Nota de Crédito por Devolución Anticipada -->
        <VBox spacing="0"
              style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3);">
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color: #F8FAFC; -fx-background-radius: 14 14 0 0; -fx-padding: 16 20; -fx-border-color: transparent transparent #E2E8F0 transparent; -fx-border-width: 0 0 1 0;">
                <StackPane minWidth="28" maxWidth="28" minHeight="28" maxHeight="28"
                           style="-fx-background-color: #2E7D32; -fx-background-radius: 7;">
                    <Label text="💳" style="-fx-font-size: 14px;"/>
                </StackPane>
                <Label text="Nota de Crédito por Devolución Anticipada" style="-fx-text-fill: #0F172A; -fx-font-size: 14px; -fx-font-weight: bold;"/>
            </HBox>

            <VBox spacing="16" style="-fx-padding: 20 24 20 24;">
                <GridPane hgap="16" vgap="12">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="20"/>
                        <ColumnConstraints percentWidth="30"/>
                        <ColumnConstraints percentWidth="20"/>
                        <ColumnConstraints percentWidth="30"/>
                    </columnConstraints>

                    <Label text="Reserva ID *" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <HBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <TextField fx:id="txtReservaIdNota" promptText="ID de reserva" HBox.hgrow="ALWAYS"
                                   style="-fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;"/>
                        <Button text="Buscar" onAction="#buscarReservaNota"
                                style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 7; -fx-padding: 8 14; -fx-cursor: hand;"/>
                    </HBox>

                    <Label text="Cliente:" GridPane.columnIndex="2" GridPane.rowIndex="0" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtClienteNota" editable="false" GridPane.columnIndex="3" GridPane.rowIndex="0"
                               style="-fx-background-color: #F8FAFC; -fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;"/>

                    <Label text="Monto Total Pagado:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtTotalPagado" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="1"
                               style="-fx-background-color: #F8FAFC; -fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;"/>

                    <Label text="Días no utilizados:" GridPane.columnIndex="2" GridPane.rowIndex="1" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtDiasNoUsados" editable="false" GridPane.columnIndex="3" GridPane.rowIndex="1"
                               style="-fx-background-color: #F8FAFC; -fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;"/>

                    <Label text="Monto a Creditar:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtMontoCredito" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="2"
                               style="-fx-background-color: #F8FAFC; -fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;"/>

                    <Label text="Motivo:" GridPane.columnIndex="2" GridPane.rowIndex="2" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtMotivoCredito" GridPane.columnIndex="3" GridPane.rowIndex="2" promptText="Ej: Devolución anticipada"
                               style="-fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;"/>
                </GridPane>

                <HBox alignment="CENTER_RIGHT" spacing="12" style="-fx-padding: 4 0 0 0;">
                    <Button text="Limpiar" onAction="#limpiarNota"
                            style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 24; -fx-cursor: hand; -fx-border-color: #E2E8F0; -fx-border-radius: 8;"/>
                    <Button text="Crear Nota de Crédito" onAction="#crearNotaCredito"
                            style="-fx-background-color: #2E7D32; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 32; -fx-cursor: hand;"/>
                </HBox>
            </VBox>
        </VBox>
    </VBox>
</ScrollPane>
