<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.factory_rent_car.Controlador.PagoController"
            style="-fx-background-color: #F8FAFC; -fx-background: #F8FAFC; -fx-border-color: transparent;">

    <VBox spacing="16" style="-fx-background-color: #F8FAFC; -fx-padding: 20;">

        <!-- Barra de búsqueda -->
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label text="Buscar:" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
            <TextField fx:id="txtBuscar" promptText="Cliente, reserva, método de pago..." HBox.hgrow="ALWAYS"
                       style="-fx-background-radius: 6; -fx-border-color: #E2E8F0; -fx-border-radius: 6; -fx-padding: 6 10;"/>
            <Button text="Buscar" onAction="#buscar"
                    style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 6 16;"/>
            <Button text="Limpiar filtro" onAction="#limpiarFiltro"
                    style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-background-radius: 6; -fx-padding: 6 16;"/>
        </HBox>

        <!-- Tabla de Pagos (ocultable) -->
        <VBox fx:id="tableContainerPagos" spacing="8" style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12;">
            <HBox alignment="CENTER_LEFT">
                <Label text="Historial de Pagos" style="-fx-text-fill: #0F172A; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnToggleTablePagos" text="📋 Ocultar Tabla" onAction="#toggleTablePagosVisibility"
                        style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-font-size: 11px; -fx-background-radius: 6; -fx-padding: 4 12; -fx-cursor: hand;"/>
            </HBox>
            <TableView fx:id="tablaPagos" prefHeight="250">
                <columns>
                    <TableColumn fx:id="colIdPago" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colFechaPago" text="Fecha" prefWidth="100"/>
                    <TableColumn fx:id="colClientePago" text="Cliente" prefWidth="180"/>
                    <TableColumn fx:id="colReservaPago" text="Reserva" prefWidth="120"/>
                    <TableColumn fx:id="colMetodoPago" text="Método" prefWidth="120"/>
                    <TableColumn fx:id="colCuentaPago" text="Cuenta" prefWidth="150"/>
                    <TableColumn fx:id="colMontoPago" text="Monto (RD$)" prefWidth="120"/>
                    <TableColumn fx:id="colTipoPago" text="Tipo" prefWidth="100"/>
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                <placeholder><Label text="No hay registros de pagos"/></placeholder>
            </TableView>
        </VBox>

        <!-- Tabla de Notas de Crédito (ocultable) -->
        <VBox fx:id="tableContainerNotas" spacing="8" style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12;">
            <HBox alignment="CENTER_LEFT">
                <Label text="Notas de Crédito Disponibles" style="-fx-text-fill: #0F172A; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnToggleTableNotas" text="📋 Ocultar Tabla" onAction="#toggleTableNotasVisibility"
                        style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-font-size: 11px; -fx-background-radius: 6; -fx-padding: 4 12; -fx-cursor: hand;"/>
            </HBox>
            <TableView fx:id="tablaNotasCredito" prefHeight="200">
                <columns>
                    <TableColumn fx:id="colIdNota" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colFechaNota" text="Fecha" prefWidth="100"/>
                    <TableColumn fx:id="colClienteNota" text="Cliente" prefWidth="180"/>
                    <TableColumn fx:id="colReservaNota" text="Reserva" prefWidth="120"/>
                    <TableColumn fx:id="colMontoNota" text="Monto (RD$)" prefWidth="120"/>
                    <TableColumn fx:id="colMotivoNota" text="Motivo" prefWidth="150"/>
                    <TableColumn fx:id="colUsadoNota" text="Usado" prefWidth="80"/>
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                <placeholder><Label text="No hay notas de crédito"/></placeholder>
            </TableView>
        </VBox>

        <!-- Sección de Registro de Pago -->
        <VBox spacing="12" style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 16;">
            <Label text="Registrar Nuevo Pago" style="-fx-text-fill: #0F172A; -fx-font-size: 14px; -fx-font-weight: bold;"/>

            <GridPane hgap="12" vgap="10">
                <columnConstraints>
                    <ColumnConstraints percentWidth="20"/>
                    <ColumnConstraints percentWidth="30"/>
                    <ColumnConstraints percentWidth="20"/>
                    <ColumnConstraints percentWidth="30"/>
                </columnConstraints>

                <Label text="Reserva ID *" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <HBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <TextField fx:id="txtReservaId" promptText="ID de reserva" HBox.hgrow="ALWAYS"/>
                    <Button text="Buscar" onAction="#buscarReserva"
                            style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 4 10;"/>
                </HBox>

                <Label text="Cliente:" GridPane.columnIndex="2" GridPane.rowIndex="0" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextField fx:id="txtCliente" editable="false" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

                <Label text="Monto Total:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextField fx:id="txtMontoTotal" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Monto Pagado:" GridPane.columnIndex="2" GridPane.rowIndex="1" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextField fx:id="txtMontoPagado" editable="false" GridPane.columnIndex="3" GridPane.rowIndex="1"/>

                <Label text="Monto Pendiente:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextField fx:id="txtMontoPendiente" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                <Label text="Notas de Crédito Disponibles:" GridPane.columnIndex="2" GridPane.rowIndex="2" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextField fx:id="txtNotasDisponibles" editable="false" GridPane.columnIndex="3" GridPane.rowIndex="2"/>

                <Label text="Aplicar Nota de Crédito:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <ComboBox fx:id="cmbNotaCredito" GridPane.columnIndex="1" GridPane.rowIndex="3" promptText="Seleccione nota de crédito"/>

                <Label text="Monto a Pagar (efectivo/tarjeta):" GridPane.columnIndex="2" GridPane.rowIndex="3" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextField fx:id="txtMontoAPagar" promptText="0.00" GridPane.columnIndex="3" GridPane.rowIndex="3"/>

                <Label text="Método de Pago *" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <ComboBox fx:id="cmbMetodoPago" GridPane.columnIndex="1" GridPane.rowIndex="4" promptText="Seleccione"/>

                <Label text="Cuenta Bancaria *" GridPane.columnIndex="2" GridPane.rowIndex="4" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <ComboBox fx:id="cmbCuenta" GridPane.columnIndex="3" GridPane.rowIndex="4" promptText="Seleccione"/>
            </GridPane>

            <HBox alignment="CENTER_RIGHT" spacing="12">
                <Button text="Limpiar" onAction="#limpiar"
                        style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-background-radius: 6; -fx-padding: 8 20;"/>
                <Button text="Registrar Pago" onAction="#registrarPago"
                        style="-fx-background-color: #1565C0; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 8 28;"/>
            </HBox>
        </VBox>

        <!-- Sección de Nota de Crédito por Devolución Anticipada -->
        <VBox spacing="12" style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 16;">
            <Label text="Nota de Crédito por Devolución Anticipada" style="-fx-text-fill: #0F172A; -fx-font-size: 14px; -fx-font-weight: bold;"/>

            <GridPane hgap="12" vgap="10">
                <columnConstraints>
                    <ColumnConstraints percentWidth="20"/>
                    <ColumnConstraints percentWidth="30"/>
                    <ColumnConstraints percentWidth="20"/>
                    <ColumnConstraints percentWidth="30"/>
                </columnConstraints>

                <Label text="Reserva ID *" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <HBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <TextField fx:id="txtReservaIdNota" promptText="ID de reserva" HBox.hgrow="ALWAYS"/>
                    <Button text="Buscar" onAction="#buscarReservaNota"
                            style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 4 10;"/>
                </HBox>

                <Label text="Cliente:" GridPane.columnIndex="2" GridPane.rowIndex="0" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextField fx:id="txtClienteNota" editable="false" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

                <Label text="Monto Total Pagado:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextField fx:id="txtTotalPagado" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Días no utilizados:" GridPane.columnIndex="2" GridPane.rowIndex="1" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextField fx:id="txtDiasNoUsados" editable="false" GridPane.columnIndex="3" GridPane.rowIndex="1"/>

                <Label text="Monto a Creditar:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextField fx:id="txtMontoCredito" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                <Label text="Motivo:" GridPane.columnIndex="2" GridPane.rowIndex="2" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <TextField fx:id="txtMotivoCredito" GridPane.columnIndex="3" GridPane.rowIndex="2" promptText="Ej: Devolución anticipada"/>
            </GridPane>

            <HBox alignment="CENTER_RIGHT" spacing="12">
                <Button text="Limpiar" onAction="#limpiarNota"
                        style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-background-radius: 6; -fx-padding: 8 20;"/>
                <Button text="Crear Nota de Crédito" onAction="#crearNotaCredito"
                        style="-fx-background-color: #2E7D32; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 8 28;"/>
            </HBox>
        </VBox>
    </VBox>
</ScrollPane>