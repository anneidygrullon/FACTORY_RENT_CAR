<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.factory_rent_car.Controlador.PagoConsultaController"
            style="-fx-background-color: #eef2f8; -fx-background: #eef2f8; -fx-border-color: transparent;">
    <VBox spacing="24" style="-fx-background-color: #eef2f8; -fx-padding: 30;">

    <!-- Header -->
    <VBox spacing="2">
        <Label text="💰 Consulta de Pagos" style="-fx-text-fill: #0F172A; -fx-font-size: 20px; -fx-font-weight: bold;"/>
        <Label text="Historial de pagos registrados en el sistema" style="-fx-text-fill: #94A3B8; -fx-font-size: 11px;"/>
    </VBox>

    <!-- Quick-access row -->
    <HBox spacing="20">
        <!-- Card 1: Consulta de Pagos (active) -->
        <VBox spacing="6" alignment="CENTER" prefWidth="200" prefHeight="80"
              style="-fx-background-color: #1565C0; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 2, 4); -fx-padding: 16 20; -fx-cursor: hand;">
            <Label text="💰" style="-fx-font-size: 22px;"/>
            <Label text="Consulta de Pagos" style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <Label text="Ver historial" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 10px;"/>
        </VBox>

        <!-- Card 2: Registrar Pago -->
        <VBox spacing="6" alignment="CENTER" prefWidth="200" prefHeight="80" onMouseClicked="#irARegistroPago"
              style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 2, 4); -fx-padding: 16 20; -fx-cursor: hand;">
            <Label text="💳" style="-fx-font-size: 22px;"/>
            <Label text="Registrar Pago" style="-fx-text-fill: #0F172A; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <Label text="Nuevo pago" style="-fx-text-fill: #94A3B8; -fx-font-size: 10px;"/>
        </VBox>

        <!-- Card 3: Notas de Crédito -->
        <VBox spacing="6" alignment="CENTER" prefWidth="200" prefHeight="80" onMouseClicked="#irANotaCredito"
              style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 2, 4); -fx-padding: 16 20; -fx-cursor: hand;">
            <Label text="📋" style="-fx-font-size: 22px;"/>
            <Label text="Notas de Crédito" style="-fx-text-fill: #0F172A; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <Label text="Gestionar notas" style="-fx-text-fill: #94A3B8; -fx-font-size: 10px;"/>
        </VBox>
    </HBox>

    <!-- Search bar -->
    <HBox spacing="12" alignment="CENTER_LEFT"
          style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2); -fx-padding: 14 18;">
        <Label text="🔍" style="-fx-font-size: 16px;"/>
        <TextField fx:id="txtBuscar" promptText="Buscar por cliente, reserva o método..." HBox.hgrow="ALWAYS"
                   style="-fx-background-radius: 8; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-padding: 8 14; -fx-font-size: 13px;"/>
        <Button text="🔍 Buscar" onAction="#buscar"
                style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 20; -fx-cursor: hand;"/>
        <Button text="Limpiar" onAction="#limpiarFiltro"
                style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-background-radius: 8; -fx-padding: 8 20; -fx-cursor: hand; -fx-border-color: #E2E8F0; -fx-border-radius: 8;"/>
    </HBox>

    <!-- Table card -->
    <VBox fx:id="tableContainerPagos" spacing="0"
          style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 2, 4); -fx-padding: 20;">
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-padding: 0 0 16 0; -fx-border-color: transparent transparent #F1F5F9 transparent; -fx-border-width: 0 0 1 0;">
            <Label text="Pagos Registrados" style="-fx-text-fill: #0F172A; -fx-font-size: 15px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnToggleTablePagos" text="Ocultar Tabla" onAction="#toggleTablePagosVisibility"
                    style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 6 14; -fx-cursor: hand; -fx-border-color: #E2E8F0; -fx-border-radius: 8;"/>
        </HBox>
        <TableView fx:id="tablaPagos" prefHeight="280"
                   style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <columns>
                <TableColumn fx:id="colIdPago" text="ID" prefWidth="60"/>
                <TableColumn fx:id="colFechaPago" text="Fecha" prefWidth="100"/>
                <TableColumn fx:id="colClientePago" text="Cliente" prefWidth="160"/>
                <TableColumn fx:id="colReservaPago" text="Reserva" prefWidth="100"/>
                <TableColumn fx:id="colMetodoPago" text="Método" prefWidth="100"/>
                <TableColumn fx:id="colCuentaPago" text="Cuenta" prefWidth="140"/>
                <TableColumn fx:id="colMontoPago" text="Monto (RD$)" prefWidth="100"/>
                <TableColumn fx:id="colTipoPago" text="Tipo" prefWidth="80"/>
            </columns>
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
            <placeholder>
                <VBox alignment="CENTER" spacing="8">
                    <Label text="📋" style="-fx-font-size: 32px;"/>
                    <Label text="No hay pagos registrados" style="-fx-text-fill: #94A3B8; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                </VBox>
            </placeholder>
        </TableView>
    </VBox>
</VBox>
</ScrollPane>
