<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="24" style="-fx-background-color: #eef2f8; -fx-padding: 30;"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.factory_rent_car.Controlador.PagoRegistroController">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <StackPane minWidth="40" maxWidth="40" minHeight="40" maxHeight="40"
                   style="-fx-background-color: #1565C0; -fx-background-radius: 10;">
            <Label text="&#x1F4B3;" style="-fx-font-size: 20px;"/>
        </StackPane>
        <VBox spacing="2">
            <Label text="Registrar Pago" style="-fx-text-fill: #0F172A; -fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Label text="Registro de pagos de reservaciones" style="-fx-text-fill: #94A3B8; -fx-font-size: 11px;"/>
        </VBox>
    </HBox>

    <!-- Quick-access row -->
    <HBox spacing="20">
        <VBox onMouseClicked="#irAConsultaPagos"
              style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 14 20; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 2);"
              alignment="CENTER">
            <Label text="&#x1F4B0; Consulta de Pagos" style="-fx-text-fill: #475569; -fx-font-size: 13px; -fx-font-weight: bold;"/>
        </VBox>
        <VBox style="-fx-background-color: #2563eb; -fx-background-radius: 10; -fx-padding: 14 20; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(37,99,235,0.3), 8, 0, 0, 4);"
              alignment="CENTER">
            <Label text="&#x1F4B3; Registrar Pago" style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
        </VBox>
        <VBox onMouseClicked="#irANotaCredito"
              style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 14 20; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 2);"
              alignment="CENTER">
            <Label text="&#x1F4CB; Notas de Crédito" style="-fx-text-fill: #475569; -fx-font-size: 13px; -fx-font-weight: bold;"/>
        </VBox>
    </HBox>

    <!-- Form card -->
    <VBox spacing="18"
          style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3); -fx-padding: 25;">

        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: #F8FAFC; -fx-background-radius: 8; -fx-padding: 12 16; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-border-width: 1;">
            <Label text="&#x1F4DD;" style="-fx-font-size: 14px;"/>
            <Label text="Registrar Pago" style="-fx-text-fill: #0F172A; -fx-font-size: 14px; -fx-font-weight: bold;"/>
        </HBox>

        <GridPane hgap="16" vgap="12">
            <columnConstraints>
                <ColumnConstraints percentWidth="18"/>
                <ColumnConstraints percentWidth="32"/>
                <ColumnConstraints percentWidth="18"/>
                <ColumnConstraints percentWidth="32"/>
            </columnConstraints>

            <!-- Row 0 -->
            <Label text="ID Reserva:" GridPane.columnIndex="0" GridPane.rowIndex="0"
                   style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <HBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <TextField fx:id="txtReservaId" promptText="ID de reserva" HBox.hgrow="ALWAYS"
                           style="-fx-background-radius: 8; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-padding: 10 14; -fx-font-size: 13px;"/>
                <Button text="&#x1F50D; Buscar" onAction="#buscarReserva"
                        style="-fx-background-color: linear-gradient(to bottom, #2563eb, #1d4ed8); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 16; -fx-cursor: hand;"/>
            </HBox>

            <Label text="Cliente:" GridPane.columnIndex="2" GridPane.rowIndex="0"
                   style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <TextField fx:id="txtCliente" editable="false" GridPane.columnIndex="3" GridPane.rowIndex="0"
                       style="-fx-background-color: #F8FAFC; -fx-background-radius: 8; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-padding: 10 14; -fx-font-size: 13px;"/>

            <!-- Row 1 -->
            <Label text="Monto Total:" GridPane.columnIndex="0" GridPane.rowIndex="1"
                   style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <TextField fx:id="txtMontoTotal" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="1"
                       style="-fx-background-color: #F8FAFC; -fx-background-radius: 8; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-padding: 10 14; -fx-font-size: 13px;"/>

            <Label text="Monto Pagado:" GridPane.columnIndex="2" GridPane.rowIndex="1"
                   style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <TextField fx:id="txtMontoPagado" editable="false" GridPane.columnIndex="3" GridPane.rowIndex="1"
                       style="-fx-background-color: #F8FAFC; -fx-background-radius: 8; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-padding: 10 14; -fx-font-size: 13px;"/>

            <!-- Row 2 -->
            <Label text="Monto Pendiente:" GridPane.columnIndex="0" GridPane.rowIndex="2"
                   style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <TextField fx:id="txtMontoPendiente" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="2"
                       style="-fx-background-color: #F8FAFC; -fx-background-radius: 8; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-padding: 10 14; -fx-font-size: 13px;"/>

            <Label text="Monto a Pagar:" GridPane.columnIndex="2" GridPane.rowIndex="2"
                   style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <TextField fx:id="txtMontoAPagar" promptText="0.00" GridPane.columnIndex="3" GridPane.rowIndex="2"
                       style="-fx-background-radius: 8; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-padding: 10 14; -fx-font-size: 13px;"/>

            <!-- Row 3 -->
            <Label text="Método de Pago:" GridPane.columnIndex="0" GridPane.rowIndex="3"
                   style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <ComboBox fx:id="cmbMetodoPago" GridPane.columnIndex="1" GridPane.rowIndex="3" promptText="Seleccione método"
                      style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-padding: 4 8; -fx-font-size: 13px;" maxWidth="1.7976931348623157E308"/>

            <Label text="Cuenta Bancaria:" GridPane.columnIndex="2" GridPane.rowIndex="3"
                   style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <ComboBox fx:id="cmbCuenta" GridPane.columnIndex="3" GridPane.rowIndex="3" promptText="Seleccione cuenta"
                      style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-padding: 4 8; -fx-font-size: 13px;" maxWidth="1.7976931348623157E308"/>
        </GridPane>

        <!-- Buttons -->
        <HBox alignment="CENTER_RIGHT" spacing="12" style="-fx-padding: 4 0 0 0;">
            <Button text="Limpiar" onAction="#limpiar"
                    style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 24; -fx-cursor: hand; -fx-border-color: #E2E8F0; -fx-border-radius: 8;"/>
            <Button text="&#x1F4B3; Registrar Pago" onAction="#registrarPago"
                    style="-fx-background-color: linear-gradient(to bottom, #2563eb, #1d4ed8); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 32; -fx-cursor: hand;"/>
        </HBox>
    </VBox>
</VBox>
