<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            style="-fx-background-color: #eef2f8; -fx-background: #eef2f8; -fx-border-color: transparent;"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.factory_rent_car.Controlador.ReclamoRegistroController">

    <VBox spacing="24" style="-fx-background-color: #eef2f8; -fx-padding: 30 35 35 35;">

        <HBox alignment="CENTER_LEFT" spacing="12">
            <StackPane minWidth="32" maxWidth="32" minHeight="32" maxHeight="32"
                       style="-fx-background-color: #1565C0; -fx-background-radius: 8;">
                <Label text="📢" style="-fx-font-size: 16px;"/>
            </StackPane>
            <VBox spacing="2">
                <Label text="Registro de Reclamo" style="-fx-text-fill: #0F172A; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Label text="Registra un nuevo reclamo de cliente" style="-fx-text-fill: #94A3B8; -fx-font-size: 11px;"/>
            </VBox>
        </HBox>

        <VBox spacing="0"
              style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3);">
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color: #F8FAFC; -fx-background-radius: 14 14 0 0; -fx-padding: 16 20; -fx-border-color: transparent transparent #E2E8F0 transparent; -fx-border-width: 0 0 1 0;">
                <Label text="Datos del Reclamo" style="-fx-text-fill: #0F172A; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="* Campos obligatorios" style="-fx-text-fill: #94A3B8; -fx-font-size: 10px;"/>
            </HBox>

            <VBox spacing="16" style="-fx-padding: 20 24;">
                <GridPane hgap="16" vgap="12">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="20"/>
                        <ColumnConstraints percentWidth="80"/>
                    </columnConstraints>

                    <Label text="Cliente *" GridPane.columnIndex="0" GridPane.rowIndex="0"
                           style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <HBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0" alignment="CENTER_LEFT">
                        <TextField fx:id="txtIdCliente" promptText="ID de cliente" prefWidth="140"
                                   style="-fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;"/>
                        <Button text="Buscar" onAction="#buscarCliente"
                                style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 7; -fx-padding: 8 14; -fx-cursor: hand;"/>
                        <TextField fx:id="txtCliente" editable="false" prefWidth="250"
                                   style="-fx-background-color: #F8FAFC; -fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 12px;"/>
                    </HBox>

                    <Label text="Empleado *" GridPane.columnIndex="0" GridPane.rowIndex="1"
                           style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <HBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="1" alignment="CENTER_LEFT">
                        <TextField fx:id="txtIdEmpleado" promptText="ID de empleado" prefWidth="140"
                                   style="-fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;"/>
                        <Button text="Buscar" onAction="#buscarEmpleado"
                                style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 7; -fx-padding: 8 14; -fx-cursor: hand;"/>
                        <TextField fx:id="txtEmpleado" editable="false" prefWidth="250"
                                   style="-fx-background-color: #F8FAFC; -fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 12px;"/>
                    </HBox>

                    <Label text="Motivo *" GridPane.columnIndex="0" GridPane.rowIndex="2"
                           style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <HBox GridPane.columnIndex="1" GridPane.rowIndex="2" alignment="CENTER_LEFT">
                        <TextField fx:id="txtMotivo" promptText="Motivo del reclamo" HBox.hgrow="ALWAYS"
                                   style="-fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;"/>
                    </HBox>

                    <Label text="Descripción" GridPane.columnIndex="0" GridPane.rowIndex="3"
                           style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <HBox GridPane.columnIndex="1" GridPane.rowIndex="3" alignment="CENTER_LEFT">
                        <TextArea fx:id="txtDescripcion" prefHeight="80" wrapText="true" HBox.hgrow="ALWAYS"
                                  style="-fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-font-size: 13px;"/>
                    </HBox>

                    <Label text="Estado inicial" GridPane.columnIndex="0" GridPane.rowIndex="4"
                           style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <ComboBox fx:id="cmbEstado" promptText="Seleccione" prefWidth="200"
                              GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                </GridPane>

                <HBox alignment="CENTER_RIGHT" spacing="12" style="-fx-padding: 4 0 0 0;">
                    <Button text="Limpiar" onAction="#limpiar"
                            style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 24; -fx-cursor: hand; -fx-border-color: #E2E8F0; -fx-border-radius: 8;"/>
                    <Button text="Registrar Reclamo" onAction="#registrarReclamo"
                            style="-fx-background-color: #1565C0; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 32; -fx-cursor: hand;"/>
                </HBox>
            </VBox>
        </VBox>
    </VBox>
</ScrollPane>