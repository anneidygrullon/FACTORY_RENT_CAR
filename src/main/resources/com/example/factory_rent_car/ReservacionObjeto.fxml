<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            style="-fx-background-color: #eef2f8; -fx-background: #eef2f8; -fx-border-color: transparent;"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.factory_rent_car.Controlador.ReservacionObjetoController">

    <VBox spacing="24" style="-fx-background-color: #eef2f8; -fx-padding: 30 35 35 35;">

        <!-- ═══ ACCESOS RÁPIDOS ═══ -->
        <VBox spacing="12">
            <Label text="Acceso Rápido" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #5a6e8a;"/>
            <GridPane hgap="18" vgap="18" alignment="CENTER">
                <columnConstraints>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                </columnConstraints>

                <VBox fx:id="cardReservaObjeto" spacing="12" alignment="CENTER"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 4); -fx-padding: 20; -fx-cursor: hand;"
                      onMouseClicked="#irAReservaObjeto" onMouseEntered="#onCardEnter" onMouseExited="#onCardExit">
                    <Label text="📦" style="-fx-font-size: 36px;"/>
                    <Label text="Reservar Objetos" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Label text="Agregar objetos a reserva" style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
                </VBox>

                <VBox fx:id="cardReservaVehiculo" spacing="12" alignment="CENTER"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 4); -fx-padding: 20; -fx-cursor: hand;"
                      onMouseClicked="#irAReservaVehiculo" onMouseEntered="#onCardEnter" onMouseExited="#onCardExit">
                    <Label text="🚗" style="-fx-font-size: 36px;"/>
                    <Label text="Reservar Vehículo" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Label text="Nueva reservación" style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
                </VBox>

                <VBox fx:id="cardIncidencias" spacing="12" alignment="CENTER"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 4); -fx-padding: 20; -fx-cursor: hand;"
                      onMouseClicked="#irAIncidencias" onMouseEntered="#onCardEnter" onMouseExited="#onCardExit">
                    <Label text="⚠️" style="-fx-font-size: 36px;"/>
                    <Label text="Incidencias" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Label text="Registrar incidencia" style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
                </VBox>

                <VBox fx:id="cardClientes" spacing="12" alignment="CENTER"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 4); -fx-padding: 20; -fx-cursor: hand;"
                      onMouseClicked="#irAClientes" onMouseEntered="#onCardEnter" onMouseExited="#onCardExit">
                    <Label text="👥" style="-fx-font-size: 36px;"/>
                    <Label text="Clientes" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Label text="Gestionar clientes" style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
                </VBox>
            </GridPane>
        </VBox>

        <!-- ═══ TÍTULO ═══ -->
        <HBox alignment="CENTER_LEFT" spacing="12">
            <StackPane minWidth="32" maxWidth="32" minHeight="32" maxHeight="32"
                       style="-fx-background-color: #1565C0; -fx-background-radius: 8;">
                <Label text="📦" style="-fx-font-size: 16px;"/>
            </StackPane>
            <VBox spacing="2">
                <Label text="Reservación de Objetos" style="-fx-text-fill: #0F172A; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Label text="Agrega objetos adicionales a una reserva existente" style="-fx-text-fill: #94A3B8; -fx-font-size: 11px;"/>
            </VBox>
        </HBox>

        <!-- ═══ BUSCAR RESERVA ═══ -->
        <HBox spacing="12" alignment="CENTER_LEFT"
              style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2); -fx-padding: 14 18;">
            <Label text="🔍" style="-fx-font-size: 16px;"/>
            <Label text="Reserva ID:" style="-fx-text-fill: #475569; -fx-font-weight: bold; -fx-font-size: 13px;"/>
            <TextField fx:id="txtReservaId" prefWidth="120" promptText="ID Reserva"
                       style="-fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-padding: 8 12; -fx-font-size: 13px;"/>
            <Button text="Buscar" onAction="#buscarReserva"
                    style="-fx-background-color: #1565C0; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 7; -fx-padding: 8 18; -fx-cursor: hand;"/>
            <Label fx:id="lblInfoReserva" style="-fx-text-fill: #2E7D32; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- ═══ OBJETOS DISPONIBLES ═══ -->
        <VBox spacing="0"
              style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3);">
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-padding: 16 20; -fx-border-color: transparent transparent #F1F5F9 transparent; -fx-border-width: 0 0 1 0;">
                <Label text="📦" style="-fx-font-size: 16px;"/>
                <Label text="Objetos Disponibles" style="-fx-text-fill: #0F172A; -fx-font-size: 15px; -fx-font-weight: bold;"/>
            </HBox>
            <TableView fx:id="tablaObjetosDisponibles" prefHeight="220"
                       style="-fx-background-color: transparent; -fx-border-color: transparent;">
                <columns>
                    <TableColumn fx:id="colObjId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colObjNombre" text="Nombre" prefWidth="150"/>
                    <TableColumn fx:id="colObjMarca" text="Marca" prefWidth="120"/>
                    <TableColumn fx:id="colObjPrecio" text="Precio (RD$/día)" prefWidth="110"/>
                    <TableColumn fx:id="colObjStock" text="Stock" prefWidth="70"/>
                    <TableColumn fx:id="colObjTipo" text="Tipo" prefWidth="100"/>
                    <TableColumn fx:id="colObjAccion" text="" prefWidth="80"/>
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                <placeholder>
                    <VBox alignment="CENTER" spacing="8">
                        <Label text="📦" style="-fx-font-size: 32px;"/>
                        <Label text="No hay objetos disponibles" style="-fx-text-fill: #94A3B8; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                    </VBox>
                </placeholder>
            </TableView>
        </VBox>

        <!-- ═══ OBJETOS RESERVADOS ═══ -->
        <VBox spacing="0"
              style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3);">
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-padding: 16 20; -fx-border-color: transparent transparent #F1F5F9 transparent; -fx-border-width: 0 0 1 0;">
                <Label text="📋" style="-fx-font-size: 16px;"/>
                <Label text="Objetos en esta Reserva" style="-fx-text-fill: #0F172A; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Eliminar seleccionados" onAction="#eliminarObjetosSeleccionados"
                        style="-fx-background-color: #FEE2E2; -fx-text-fill: #DC2626; -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 6 14; -fx-cursor: hand; -fx-border-color: #FECACA; -fx-border-radius: 8;"/>
            </HBox>
            <TableView fx:id="tablaObjetosReservados" prefHeight="220"
                       style="-fx-background-color: transparent; -fx-border-color: transparent;">
                <columns>
                    <TableColumn fx:id="colResObjId" text="ID" prefWidth="70"/>
                    <TableColumn fx:id="colResObjNombre" text="Nombre" prefWidth="150"/>
                    <TableColumn fx:id="colResObjMarca" text="Marca" prefWidth="120"/>
                    <TableColumn fx:id="colResObjPrecio" text="Precio (RD$/día)" prefWidth="110"/>
                    <TableColumn fx:id="colResObjCantidad" text="Cantidad" prefWidth="80"/>
                    <TableColumn fx:id="colResObjAccionEliminar" text="" prefWidth="80"/>
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                <placeholder>
                    <VBox alignment="CENTER" spacing="8">
                        <Label text="📋" style="-fx-font-size: 32px;"/>
                        <Label text="No hay objetos reservados aún" style="-fx-text-fill: #94A3B8; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                    </VBox>
                </placeholder>
            </TableView>
        </VBox>

        <!-- ═══ TOTALES ═══ -->
        <HBox spacing="20" alignment="CENTER_RIGHT"
              style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2); -fx-padding: 16 24;">
            <VBox alignment="CENTER_RIGHT" spacing="2">
                <Label text="Total Objetos:" style="-fx-text-fill: #475569; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                <Label fx:id="lblTotalObjetos" text="RD$ 0.00" style="-fx-text-fill: #1565C0; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            </VBox>
            <Separator orientation="VERTICAL" prefHeight="40"/>
            <VBox alignment="CENTER_RIGHT" spacing="2">
                <Label text="Total Reserva Original:" style="-fx-text-fill: #475569; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                <Label fx:id="lblTotalReserva" text="RD$ 0.00" style="-fx-text-fill: #0F172A; -fx-font-size: 16px;"/>
            </VBox>
            <Separator orientation="VERTICAL" prefHeight="40"/>
            <VBox alignment="CENTER_RIGHT" spacing="2">
                <Label text="GRAN TOTAL:" style="-fx-text-fill: #475569; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                <Label fx:id="lblTotalGeneral" text="RD$ 0.00" style="-fx-text-fill: #2E7D32; -fx-font-size: 20px; -fx-font-weight: bold;"/>
            </VBox>
        </HBox>

        <!-- ═══ BOTONES ═══ -->
        <HBox alignment="CENTER_RIGHT" spacing="12">
            <Button text="Limpiar" onAction="#limpiar"
                    style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 24; -fx-cursor: hand; -fx-border-color: #E2E8F0; -fx-border-radius: 8;"/>
            <Button text="Guardar Cambios" onAction="#guardarCambios"
                    style="-fx-background-color: #1565C0; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 32; -fx-cursor: hand;"/>
        </HBox>
    </VBox>
</ScrollPane>
