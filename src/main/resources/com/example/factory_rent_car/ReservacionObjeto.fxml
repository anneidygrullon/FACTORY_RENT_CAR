<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            style="-fx-background-color: #F8FAFC; -fx-background: #F8FAFC; -fx-border-color: transparent;"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.factory_rent_car.Controlador.ReservacionObjetoController">

    <VBox spacing="16" style="-fx-background-color: #F8FAFC; -fx-padding: 20;">

        <!-- Buscar reserva -->
        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label text="Reserva ID:" style="-fx-text-fill: #475569; -fx-font-weight: bold; -fx-font-size: 13px;"/>
            <TextField fx:id="txtReservaId" prefWidth="100" promptText="ID Reserva"/>
            <Button text="Buscar" onAction="#buscarReserva"
                    style="-fx-background-color: #1565C0; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 6 16;"/>
            <Label fx:id="lblInfoReserva" style="-fx-text-fill: #2E7D32; -fx-font-size: 12px;"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- Objetos disponibles -->
        <VBox spacing="8" style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12;">
            <Label text="Objetos Disponibles" style="-fx-text-fill: #0F172A; -fx-font-size: 14px; -fx-font-weight: bold;"/>
            <TableView fx:id="tablaObjetosDisponibles" prefHeight="200">
                <columns>
                    <TableColumn fx:id="colObjId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colObjNombre" text="Nombre" prefWidth="150"/>
                    <TableColumn fx:id="colObjMarca" text="Marca" prefWidth="120"/>
                    <TableColumn fx:id="colObjPrecio" text="Precio (RD$/día)" prefWidth="110"/>
                    <TableColumn fx:id="colObjStock" text="Stock" prefWidth="70"/>
                    <TableColumn fx:id="colObjTipo" text="Tipo" prefWidth="100"/>
                    <TableColumn fx:id="colObjAccion" text="" prefWidth="80"/>
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                <placeholder><Label text="No hay objetos disponibles"/></placeholder>
            </TableView>
        </VBox>

        <!-- Objetos reservados -->
        <VBox spacing="8" style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12;">
            <HBox alignment="CENTER_LEFT">
                <Label text="Objetos Reservados en esta Reserva" style="-fx-text-fill: #0F172A; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Eliminar seleccionados" onAction="#eliminarObjetosSeleccionados"
                        style="-fx-background-color: #FEE2E2; -fx-text-fill: #DC2626; -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 4 12;"/>
            </HBox>
            <TableView fx:id="tablaObjetosReservados" prefHeight="200">
                <columns>
                    <TableColumn fx:id="colResObjId" text="ID" prefWidth="70"/>
                    <TableColumn fx:id="colResObjNombre" text="Nombre" prefWidth="150"/>
                    <TableColumn fx:id="colResObjMarca" text="Marca" prefWidth="120"/>
                    <TableColumn fx:id="colResObjPrecio" text="Precio (RD$/día)" prefWidth="110"/>
                    <TableColumn fx:id="colResObjCantidad" text="Cantidad" prefWidth="80"/>
                    <TableColumn fx:id="colResObjAccionEliminar" text="" prefWidth="80"/>
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                <placeholder><Label text="No hay objetos reservados aún"/></placeholder>
            </TableView>
        </VBox>

        <!-- ═══ TOTALES ═══ -->
        <HBox alignment="CENTER_RIGHT" spacing="20">
            <VBox alignment="CENTER_RIGHT">
                <Label text="Total Objetos:" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <Label fx:id="lblTotalObjetos" text="RD$ 0.00" style="-fx-text-fill: #1565C0; -fx-font-size: 16px; -fx-font-weight: bold;"/>
            </VBox>
            <VBox alignment="CENTER_RIGHT">
                <Label text="Total Reserva Original:" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <Label fx:id="lblTotalReserva" text="RD$ 0.00" style="-fx-text-fill: #0F172A; -fx-font-size: 16px;"/>
            </VBox>
            <VBox alignment="CENTER_RIGHT">
                <Label text="GRAN TOTAL:" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <Label fx:id="lblTotalGeneral" text="RD$ 0.00" style="-fx-text-fill: #2E7D32; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            </VBox>
        </HBox>

        <!-- Botones -->
        <HBox alignment="CENTER_RIGHT" spacing="12">
            <Button text="Limpiar" onAction="#limpiar"
                    style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 20;"/>
            <Button text="Guardar Cambios" onAction="#guardarCambios"
                    style="-fx-background-color: #1565C0; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 28;"/>
        </HBox>

    </VBox>
</ScrollPane>