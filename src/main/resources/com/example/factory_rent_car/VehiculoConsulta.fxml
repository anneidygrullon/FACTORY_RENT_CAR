<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.factory_rent_car.Controlador.VehiculoConsultaController"
            style="-fx-background-color: #eef2f8; -fx-background: #eef2f8; -fx-border-color: transparent;">

    <VBox spacing="24" style="-fx-background-color: #eef2f8; -fx-padding: 30 35 35 35;">

        <!-- Title section -->
        <HBox alignment="CENTER_LEFT" spacing="12">
            <StackPane prefWidth="32" prefHeight="32"
                       style="-fx-background-color: #1565C0; -fx-background-radius: 8; -fx-alignment: center;">
                <Label text="&#x1F697;" style="-fx-font-size: 16px;"/>
            </StackPane>
            <VBox spacing="2">
                <Label text="Consulta de Vehículos" style="-fx-text-fill: #0F172A; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Label text="Visualiza y gestiona el estado de los vehículos" style="-fx-text-fill: #94A3B8; -fx-font-size: 11px;"/>
            </VBox>
        </HBox>

        <!-- Search bar card -->
        <HBox spacing="12" alignment="CENTER_LEFT"
              style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2); -fx-padding: 14 18;">
            <Label text="&#x1F50D;" style="-fx-font-size: 14px;"/>
            <TextField fx:id="txtBuscar" promptText="Marca, modelo, placa..." HBox.hgrow="ALWAYS"
                       style="-fx-background-radius: 8; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-padding: 8 14; -fx-font-size: 13px;"/>
            <Button text="Buscar" onAction="#buscar"
                    style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 20; -fx-cursor: hand;"/>
            <Button text="Limpiar" onAction="#limpiarFiltro"
                    style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-background-radius: 8; -fx-padding: 8 20; -fx-cursor: hand; -fx-border-color: #E2E8F0; -fx-border-radius: 8;"/>
        </HBox>

        <!-- Table card -->
        <VBox spacing="0"
              style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2); -fx-padding: 0;">
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 16 20; -fx-border-color: transparent transparent #F1F5F9 transparent; -fx-border-width: 0 0 1 0;">
                <Label text="&#x1F4CB;" style="-fx-font-size: 16px;"/>
                <Label text="Lista de Vehículos" style="-fx-text-fill: #0F172A; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>
            <TableView fx:id="tablaVehiculos" prefHeight="450"
                       style="-fx-background-color: transparent; -fx-border-color: transparent;">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colMarca" text="Marca" prefWidth="100"/>
                    <TableColumn fx:id="colModelo" text="Modelo" prefWidth="100"/>
                    <TableColumn fx:id="colPlaca" text="Placa" prefWidth="100"/>
                    <TableColumn fx:id="colColor" text="Color" prefWidth="80"/>
                    <TableColumn fx:id="colKilometraje" text="Km" prefWidth="80"/>
                    <TableColumn fx:id="colCombustible" text="Combustible" prefWidth="100"/>
                    <TableColumn fx:id="colPasajeros" text="Pasajeros" prefWidth="80"/>
                    <TableColumn fx:id="colEstado" text="Estado" prefWidth="130"/>
                    <TableColumn fx:id="colPrecio" text="Precio x día (RD$)" prefWidth="120"/>
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                <placeholder>
                    <VBox alignment="CENTER" spacing="8">
                        <Label text="No hay vehículos registrados" style="-fx-text-fill: #94A3B8;"/>
                    </VBox>
                </placeholder>
            </TableView>
        </VBox>

        <!-- State change card -->
        <VBox spacing="0"
              style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3);">
            <HBox alignment="CENTER_LEFT" style="-fx-background-color: #F8FAFC; -fx-background-radius: 14 14 0 0; -fx-padding: 16 20; -fx-border-color: transparent transparent #E2E8F0 transparent; -fx-border-width: 0 0 1 0;">
                <Label text="&#x270F;" style="-fx-font-size: 16px;"/>
                <Label text="Cambiar Estado del Vehículo" style="-fx-text-fill: #0F172A; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>
            <VBox style="-fx-padding: 20 24; -fx-spacing: 16;">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Nuevo estado:" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <ComboBox fx:id="cmbEstado" prefWidth="200" promptText="Seleccione estado"
                              style="-fx-background-radius: 7; -fx-border-color: #E2E8F0; -fx-border-radius: 7; -fx-font-size: 13px;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Actualizar Estado" onAction="#actualizarEstado"
                            style="-fx-background-color: #1565C0; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 32; -fx-cursor: hand;"/>
                </HBox>
            </VBox>
        </VBox>
    </VBox>
</ScrollPane>
