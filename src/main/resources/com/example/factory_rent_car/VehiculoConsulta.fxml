<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.factory_rent_car.Controlador.VehiculoConsultaController"
            style="-fx-background-color: #F8FAFC; -fx-background: #F8FAFC; -fx-border-color: transparent;">

    <VBox spacing="16" style="-fx-background-color: #F8FAFC; -fx-padding: 20;">

        <!-- Barra de búsqueda -->
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label text="Buscar:" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
            <TextField fx:id="txtBuscar" promptText="Marca, modelo, placa..." HBox.hgrow="ALWAYS"
                       style="-fx-background-radius: 6; -fx-border-color: #E2E8F0; -fx-border-radius: 6; -fx-padding: 6 10;"/>
            <Button text="Buscar" onAction="#buscar"
                    style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 6 16;"/>
            <Button text="Limpiar filtro" onAction="#limpiarFiltro"
                    style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-background-radius: 6; -fx-padding: 6 16;"/>
        </HBox>

        <!-- Tabla de vehículos -->
        <VBox spacing="8" style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12;">
            <Label text="Lista de Vehículos" style="-fx-text-fill: #0F172A; -fx-font-size: 14px; -fx-font-weight: bold;"/>
            <TableView fx:id="tablaVehiculos" prefHeight="450">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colMarca" text="Marca" prefWidth="100"/>
                    <TableColumn fx:id="colModelo" text="Modelo" prefWidth="100"/>
                    <TableColumn fx:id="colPlaca" text="Placa" prefWidth="100"/>
                    <TableColumn fx:id="colColor" text="Color" prefWidth="80"/>
                    <TableColumn fx:id="colKilometraje" text="Km" prefWidth="80"/>
                    <TableColumn fx:id="colCombustible" text="Combustible" prefWidth="100"/>
                    <TableColumn fx:id="colPasajeros" text="Pasajeros" prefWidth="80"/>
                    <TableColumn fx:id="colEstado" text="Estado" prefWidth="130"/>
                    <TableColumn fx:id="colPrecio" text="Precio x día (RD$)" prefWidth="120"/>
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                <placeholder><Label text="No hay vehículos registrados"/></placeholder>
            </TableView>
        </VBox>

        <!-- Panel para editar estado -->
        <VBox spacing="8" style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12;">
            <Label text="Cambiar Estado del Vehículo Seleccionado" style="-fx-text-fill: #0F172A; -fx-font-size: 14px; -fx-font-weight: bold;"/>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Nuevo estado:" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
                <ComboBox fx:id="cmbEstado" prefWidth="180" promptText="Seleccione estado"/>
                <Button text="Actualizar Estado" onAction="#actualizarEstado"
                        style="-fx-background-color: #1565C0; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 6 16;"/>
            </HBox>
        </VBox>

    </VBox>
</ScrollPane>